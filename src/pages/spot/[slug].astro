// 1. Astroのビルド時に実行される処理（サーバーサイド）
export async function getStaticPaths() {
  // スプレッドシート（CSV形式で公開したもの）のURL
  const LOCAL_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vTia8V00j15toSprtd2bQV4JWrZprRz7m_cf73IZla6KOu62wtunUjCrb9wKkyNthWep8TfDeT8HW2B/pub?gid=1467172273&single=true&output=csv";
  
  const response = await fetch(LOCAL_CSV_URL);
  const csvText = await response.text();

  // CSVをパース（解析）する関数
  function parseCSV(text) {
    const result = [];
    let row = [];
    let current = '';
    let inQuotes = false;
    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      if (char === '"') {
        if (inQuotes && text[i + 1] === '"') { current += '"'; i++; }
        else { inQuotes = !inQuotes; }
      } else if (char === ',' && !inQuotes) {
        row.push(current); current = '';
      } else if ((char === '\n' || char === '\r') && !inQuotes) {
        if (char === '\r' && text[i + 1] === '\n') { i++; }
        row.push(current); result.push(row); row = []; current = '';
      } else { current += char; }
    }
    if (current !== '' || row.length > 0) { row.push(current); result.push(row); }
    return result;
  }

  const rows = parseCSV(csvText);
  if (rows.length < 2) return [];

  // ヘッダー行を整形（空白削除・小文字化）
  const header = rows[0].map(h => h.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase());
  
  const spots = [];
  for(let i=1; i<rows.length; i++) {
    const values = rows[i];
    if(!values || values.length <= 1) continue;
    
    // 一旦生のデータを取得
    const rawSpot = {};
    header.forEach((h, index) => {
      rawSpot[h] = values[index] ? values[index].trim() : '';
    });

    const spot = {};
    spot.title = rawSpot['スポット名'] || rawSpot['タイトル'] || rawSpot['title'] || '';
    spot.desc = rawSpot['紹介文（パパママ目線）'] || rawSpot['紹介文'] || rawSpot['説明'] || rawSpot['desc'] || '';
    
    // 英語用の列データを取得
    spot.title_en = rawSpot['title_en'] || '';
    spot.desc_en = rawSpot['desc_en'] || '';
    spot.tag_en = rawSpot['tag_en'] || '';

    // 写真の複数枚対応
    spot.image = rawSpot['写真'] || rawSpot['画像'] || rawSpot['image'] || '';
    spot.image2 = rawSpot['写真2'] || rawSpot['画像2'] || rawSpot['image2'] || '';
    spot.image3 = rawSpot['写真3'] || rawSpot['画像3'] || rawSpot['image3'] || '';
    spot.image4 = rawSpot['写真4'] || rawSpot['画像4'] || rawSpot['image4'] || '';

    spot.area = rawSpot['エリア'] || rawSpot['area'] || '';
    spot.tag = rawSpot['タグ'] || rawSpot['tag'] || '';
    spot.lat_lng_raw = rawSpot['lat_lng_raw'] || rawSpot['緯度経度'] || '';
    spot.map_url = rawSpot['googleマップのurl'] || rawSpot['googleマップのurl(共有リンク)'] || rawSpot['地図url'] || rawSpot['map_url'] || '';
    spot.author = rawSpot['ニックネーム'] || rawSpot['撮影者'] || rawSpot['author'] || rawSpot['nickname'] || '';
    spot.sns = rawSpot['sns'] || rawSpot['snsurl'] || rawSpot['url'] || rawSpot['link'] || '';

    if(spot.title) {
      spots.push(spot);
    }
  }

  // 記事の数だけページ（URL）を生成
  return spots.map(spot => {
    let slug = spot.title.replace(/[\/\\]/g, '-');
    return {
      params: { slug: slug },
      props: { spot }, 
    };
  });
}

// 2. 各ページに渡されたデータを受け取る
const { spot } = Astro.props;

// GoogleドライブIDを抽出する関数
function getDriveId(urlOrId) {
  if (!urlOrId) return '';
  const match = urlOrId.toString().match(/[-\w]{25,}/);
  return match ? match[0] : '';
}

// 画像URLの整形（メイン画像）
let rawImage = spot.image || '';
let firstImage = rawImage.includes(',') ? rawImage.split(',')[0].trim() : rawImage.trim();
let imageUrl = "https://placehold.co/600x800/e2e8f0/94a3b8?text=No+Image";
let driveId = getDriveId(firstImage);

if (driveId) {
  imageUrl = `https://lh3.googleusercontent.com/d/${driveId}=w1200`;
} else if (firstImage.startsWith('http')) {
  imageUrl = firstImage;
}

// サブ画像（複数画像）のリストを作成
const subImages = [];
[spot.image2, spot.image3, spot.image4].forEach(img => {
  if (img) {
    const dId = getDriveId(img);
    if (dId) subImages.push({ id: dId, url: `https://lh3.googleusercontent.com/d/${dId}=w1200` });
  }
});

// Googleマップ用URLの準備
let mapUrl = spot.map_url || '';
if(!mapUrl && spot.lat_lng_raw) {
   mapUrl = `https://www.google.com/maps/search/?api=1&query=${spot.lat_lng_raw}`;
}

// エリアの表示名
const areaLabels = {
  'all': 'ぜんぶ', 'mihara': '三原市街', 'daiwa': '大和', 'kui': '久井', 'hongo': '本郷', 'sagi': '佐木島'
};
const areaLabelsEn = {
  'all': 'ALL', 'mihara': 'MIHARA', 'daiwa': 'DAIWA', 'kui': 'KUI', 'hongo': 'HONGO', 'sagi': 'SAGI'
};
const displayArea = areaLabels[spot.area] || spot.area || '三原市';
const displayAreaEn = areaLabelsEn[spot.area] || spot.area || 'Mihara';

// 英語データがない場合のフォールバック
const finalTitleEn = spot.title_en || spot.title;
const finalDescEn = spot.desc_en || "No description available in English yet.";
const finalTagEn = spot.tag_en || spot.tag || "👟 Mihara Walk";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  
  <title>{spot.title} | みはらさんぽログ</title>
  <meta name="description" content={spot.desc}>
  
  <meta property="og:type" content="article">
  <meta property="og:title" content={`${spot.title} | みはらさんぽログ`}>
  <meta property="og:description" content={spot.desc}>
  <meta property="og:image" content={imageUrl}>
  <meta name="twitter:card" content="summary_large_image">

  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <style>
    body { 
      font-family: 'Zen Maru Gothic', sans-serif; 
      color: #1a1a1a; 
      background-color: #f1f5f9; 
      word-break: break-all;
    }
    .serif-custom { font-family: 'Noto Serif JP', serif; }
    
    /* ▼ 横スクロールギャラリー用 ▼ */
    .gallery-container {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none; /* Firefox */
      -webkit-overflow-scrolling: touch;
    }
    .gallery-container::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
    .gallery-item {
      flex: 0 0 100%;
      scroll-snap-align: start;
      /* PCでのドラッグ時に画像だけ引っ張れるのを防ぐ */
      user-select: none;
      -webkit-user-drag: none;
    }
    .gallery-item img {
      pointer-events: none; /* 画像自体のドラッグを禁止 */
    }

    /* シェアボタン用のスタイル */
    .share-btn-group { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 10px; }
    .share-btn { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: #f1f5f9; color: #64748b; font-size: 16px; transition: all 0.3s; text-decoration: none; border: 1px solid transparent; cursor: pointer; }
    .share-btn:hover { transform: translateY(-2px); color: white; }
    .share-btn.x-twitter:hover { background: #000; color: #fff !important; }
    .share-btn.facebook:hover { background: #1877f2; color: #fff !important; }
    .share-btn.line:hover { background: #06c755; color: #fff !important; }
    .share-btn.copy-link:hover { background: #004098; color: #fff !important; }
    #copy-success-msg { font-size: 10px; font-weight: bold; color: #004098; opacity: 0; transition: opacity 0.3s ease; height: 14px; text-align: center; }
    #copy-success-msg.show { opacity: 1; }

    /* 完全切り替え用のCSS */
    .lang-jp, .lang-en { display: none; }
    body.is-jp .lang-jp { display: block; }
    body.is-jp span.lang-jp, body.is-jp a.lang-jp, body.is-jp div.lang-jp { display: inline; }
    body.is-jp div.lang-jp.block-elem { display: block; }
    body.is-en .lang-en { display: block; }
    body.is-en span.lang-en, body.is-en a.lang-en, body.is-en div.lang-en { display: inline; }
    body.is-en div.lang-en.block-elem { display: block; }
  </style>

  <!-- ▼ 言語判定プログラム ▼ -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        let lang = urlParams.get('lang');
        
        if (!lang) {
             lang = localStorage.getItem('siteLang') || 'jp';
        }
        
        if (lang === 'en') {
            document.body.classList.add('is-en');
            const spotTitleEn = document.getElementById('title-en-data').textContent;
            document.title = spotTitleEn + " | Mihara Walk Log";
            const backLink = document.getElementById('back-link');
            if(backLink) backLink.href = '/?lang=en#local-insights';
        } else {
            document.body.classList.add('is-jp');
            const backLink = document.getElementById('back-link');
            if(backLink) backLink.href = '/?lang=jp#local-insights';
        }
    });
  </script>

  <script is:inline>
    function handleFallbackErr(img, driveId) {
      if (!img || !driveId) return;
      const step = parseInt(img.dataset.fStep || '0');
      if (step === 0) {
        img.dataset.fStep = '1';
        img.src = 'https://drive.google.com/uc?export=view&id=' + driveId;
      } else if (step === 1) {
        img.dataset.fStep = '2';
        img.src = 'https://drive.google.com/thumbnail?id=' + driveId + '&sz=w1000';
      } else if (step === 2) {
        img.dataset.fStep = '3';
        img.src = 'https://wsrv.nl/?url=https://drive.google.com/uc?export=view%26id=' + driveId;
      } else {
        img.onerror = null;
        img.src = 'https://placehold.co/600x800/e2e8f0/94a3b8?text=Image+Blocked';
      }
    }
  </script>
</head>
<body>
  
  <nav class="bg-white/90 backdrop-blur-md border-b border-gray-200 px-4 py-3 sticky top-0 z-50 flex items-center justify-between shadow-sm">
      <a href="/#local-insights" id="back-link" class="text-[#004098] font-bold text-xs sm:text-sm flex items-center gap-2 hover:opacity-70 transition">
        <i class="fa-solid fa-arrow-left"></i> 
        <span class="lang-jp">さんぽログへ戻る</span>
        <span class="lang-en">Back to Walk Log</span>
      </a>
      <div class="text-[10px] sm:text-xs font-bold text-gray-400 tracking-widest uppercase">Mihara Rediscover</div>
  </nav>

  <main class="max-w-3xl mx-auto bg-white min-h-screen shadow-md pb-24">
    
    <!-- 隠しデータ -->
    <span id="title-en-data" style="display:none;">{finalTitleEn}</span>

    <!-- ▼ ギャラリー部分（横スクロール対応） ▼ -->
    <div class="w-full bg-[#f8f9fa]">
        
        <div class="relative">
            <!-- 写真部分 -->
            <div id="spot-gallery" class="gallery-container w-full h-[60vh] sm:h-[80vh] cursor-grab">
                <div class="gallery-item h-full flex items-center justify-center relative">
                    <img src={imageUrl} alt={spot.title} class="w-full h-full object-contain" data-f-step="0" onerror={`handleFallbackErr(this, '${driveId}')`} />
                </div>
                <!-- さんぽログに写真2〜4があれば表示する -->
                {subImages.map((img, index) => (
                    <div class="gallery-item h-full flex items-center justify-center relative bg-[#f1f5f9]">
                        <img src={img.url} alt={`${spot.title} - 写真${index + 2}`} class="w-full h-full object-contain" data-f-step="0" onerror={`handleFallbackErr(this, '${img.id}')`} />
                    </div>
                ))}
            </div>
            
            <div class="absolute top-4 left-4 bg-[#004098]/90 text-white text-[10px] font-bold px-3 py-1.5 rounded flex items-center gap-1.5 shadow-lg z-10 pointer-events-none">
                <i class="fa-solid fa-location-dot"></i> 
                <span class="lang-jp">{displayArea}</span>
                <span class="lang-en">{displayAreaEn}</span>
            </div>
        </div>
        
        <!-- 写真枠の下に配置されるスワイプ案内（複数枚ある時だけ表示） -->
        {subImages.length > 0 && (
            <div class="flex justify-center items-center gap-4 py-3 bg-[#f8f9fa] border-t border-gray-200/50 text-gray-400 pointer-events-none">
                <i class="fa-solid fa-chevron-left text-[10px]"></i>
                <div class="text-[10px] font-bold tracking-widest flex items-center gap-1.5 uppercase">
                    <span class="lang-jp">写真をスワイプ</span>
                    <span class="lang-en">Swipe Photos</span>
                </div>
                <i class="fa-solid fa-chevron-right text-[10px]"></i>
            </div>
        )}
        
    </div>

    <!-- ▼ PCでのドラッグ（スワイプ）を可能にする魔法のプログラム ▼ -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
          const slider = document.getElementById('spot-gallery');
          if (!slider) return;

          let isDown = false;
          let startX;
          let scrollLeft;

          slider.addEventListener('mousedown', (e) => {
              isDown = true;
              slider.classList.add('cursor-grabbing'); 
              slider.classList.remove('cursor-grab');
              startX = e.pageX - slider.offsetLeft;
              scrollLeft = slider.scrollLeft;
          });
          slider.addEventListener('mouseleave', () => {
              isDown = false;
              slider.classList.remove('cursor-grabbing');
              slider.classList.add('cursor-grab');
          });
          slider.addEventListener('mouseup', () => {
              isDown = false;
              slider.classList.remove('cursor-grabbing');
              slider.classList.add('cursor-grab');
          });
          slider.addEventListener('mousemove', (e) => {
              if (!isDown) return;
              e.preventDefault(); 
              const x = e.pageX - slider.offsetLeft;
              const walk = (x - startX) * 1.5; 
              slider.scrollLeft = scrollLeft - walk;
          });
      });
    </script>
    
    <div class="px-6 sm:px-10 py-8 sm:py-12">
        
       <div class="flex items-center gap-2 mb-4">
         <span class="text-white bg-[#004098]/90 text-[10px] font-bold px-3 py-1.5 rounded shadow-sm lang-jp">
           {spot.tag || '👟 みはらさんぽ'}
         </span>
         <span class="text-white bg-[#004098]/90 text-[10px] font-bold px-3 py-1.5 rounded shadow-sm lang-en">
           {finalTagEn}
         </span>
       </div>
       
       <h1 class="text-2xl sm:text-3xl font-bold text-[#004098] serif-custom mb-8 leading-relaxed border-b-2 border-blue-50 pb-6">
           <span class="lang-jp">{spot.title}</span>
           <span class="lang-en font-sans">{finalTitleEn}</span>
       </h1>
       
       <div id="desc-container-jp" class="lang-jp block-elem text-gray-700 leading-loose text-sm sm:text-base whitespace-pre-line mb-12" set:html={spot.desc}></div>
       <div id="desc-container-en" class="lang-en block-elem text-gray-700 leading-loose text-sm sm:text-base whitespace-pre-line mb-12" set:html={finalDescEn}></div>

       <script is:inline>
         ['desc-container-jp', 'desc-container-en'].forEach(id => {
             const descEl = document.getElementById(id);
             if (descEl) {
               const urlRegex = /(https?:\/\/[^\s<]+)/g;
               descEl.innerHTML = descEl.innerHTML.replace(urlRegex, function(url) {
                 return `<a href="${url}" target="_blank" rel="noopener noreferrer" style="color: #004098; text-decoration: underline;">${url}</a>`;
               });
             }
         });
       </script>

       {mapUrl && (
         <a href={mapUrl} target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-blue-50 text-[#004098] border border-[#004098] font-bold py-4 rounded-lg hover:bg-[#004098] hover:text-white transition-all shadow-sm">
           <i class="fa-solid fa-map-location-dot mr-2"></i> 
           <span class="lang-jp">この場所をGoogleマップで見る</span>
           <span class="lang-en">View on Google Maps</span>
         </a>
       )}

       {spot.sns && (
         <a href={spot.sns} target="_blank" rel="noopener noreferrer" class="block w-full mt-4 text-center text-white font-bold py-4 rounded-lg shadow-md transition-transform hover:-translate-y-1" style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
           <i class="fa-brands fa-instagram text-xl mr-2 align-middle"></i> 
           <span class="lang-jp">Instagramでこの投稿を見る</span>
           <span class="lang-en">View this post on Instagram</span>
         </a>
       )}
       
       <div class="mt-16 pt-8 border-t border-dashed border-gray-200 flex justify-between items-center mb-8">
         <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Photo by {spot.author || 'MICHIM'}</span>
       </div>
       
       <div class="pt-4 text-center">
           <p class="text-[9px] font-bold text-slate-400 mb-4 tracking-widest uppercase">SHARE THIS SPOT</p>
           <div class="share-btn-group" id="share-buttons">
               <a id="share-x" href="#" target="_blank" rel="noopener noreferrer" class="share-btn x-twitter" title="X (Twitter)"><i class="fa-brands fa-x-twitter"></i></a>
               <a id="share-fb" href="#" target="_blank" rel="noopener noreferrer" class="share-btn facebook" title="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
               <a id="share-line" href="#" target="_blank" rel="noopener noreferrer" class="share-btn line" title="LINE"><i class="fa-brands fa-line"></i></a>
               <button id="share-copy" class="share-btn copy-link" title="Copy Link"><i class="fa-solid fa-link"></i></button>
           </div>
           <p id="copy-success-msg">
               <span class="lang-jp">リンクをコピーしました！</span>
               <span class="lang-en">Link copied to clipboard!</span>
           </p>
       </div>
       
       <script is:inline>
         document.addEventListener('DOMContentLoaded', () => {
           const shareUrl = window.location.href;
           const isEn = document.body.classList.contains('is-en');
           
           const spotTitleJp = document.title.split(' | ')[0];
           const spotTitleEn = document.getElementById('title-en-data').textContent;
           
           const shareTextJp = `みはらさんぽログ！「${spotTitleJp}」\n#三原市まち歩き #みはらさんぽ`;
           const shareTextEn = `Mihara Walk Log! "${spotTitleEn}"\n#Mihara #JapanTravel`;
           
           const finalShareText = isEn ? shareTextEn : shareTextJp;
           
           document.getElementById('share-x').href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(finalShareText)}&url=${encodeURIComponent(shareUrl)}`;
           document.getElementById('share-fb').href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
           document.getElementById('share-line').href = `https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(shareUrl)}`;
           
           const copyBtn = document.getElementById('share-copy');
           const copyMsg = document.getElementById('copy-success-msg');
           
           copyBtn.addEventListener('click', () => {
             if (navigator.clipboard && navigator.clipboard.writeText) {
               navigator.clipboard.writeText(shareUrl).then(() => {
                 copyMsg.classList.add('show');
                 setTimeout(() => copyMsg.classList.remove('show'), 2000);
               });
             } else {
               const textArea = document.createElement("textarea");
               textArea.value = shareUrl;
               document.body.appendChild(textArea);
               textArea.select();
               document.execCommand('copy');
               document.body.removeChild(textArea);
               copyMsg.classList.add('show');
               setTimeout(() => copyMsg.classList.remove('show'), 2000);
             }
           });
         });
       </script>
       
    </div>
  </main>

</body>
</html>