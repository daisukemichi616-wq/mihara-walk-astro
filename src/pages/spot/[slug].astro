---
// 1. Astroのビルド時に実行される処理（サーバーサイド）
export async function getStaticPaths() {
  // PHOTO MAP用のスプレッドシートURL
  const CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vR0jkQnLXsIL33pmO60BCd0hIr_v5xh34cJ_IWAHkF0pTaj855pzicmNoVx6W8CPK3MEhlp-irodPSE/pub?gid=1232979489&single=true&output=csv";
  
  const response = await fetch(CSV_URL);
  const csvText = await response.text();

  function parseCSV(text) {
    const result = [];
    let row = [];
    let current = '';
    let inQuotes = false;
    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      if (char === '"') {
        if (inQuotes && text[i + 1] === '"') { current += '"'; i++; }
        else { inQuotes = !inQuotes; }
      } else if (char === ',' && !inQuotes) {
        row.push(current); current = '';
      } else if ((char === '\n' || char === '\r') && !inQuotes) {
        if (char === '\r' && text[i + 1] === '\n') { i++; }
        row.push(current); result.push(row); row = []; current = '';
      } else { current += char; }
    }
    if (current !== '' || row.length > 0) { row.push(current); result.push(row); }
    return result;
  }

  const rows = parseCSV(csvText);
  if (rows.length < 2) return [];

  const header = rows[0].map(h => h.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase());
  
  const spots = [];
  for(let i=1; i<rows.length; i++) {
    const values = rows[i];
    if(!values || values.length <= 1) continue;
    
    const rawSpot = {};
    header.forEach((h, index) => {
      rawSpot[h] = values[index] ? values[index].trim() : '';
    });

    const spot = {};
    spot.title = rawSpot['スポット名'] || rawSpot['タイトル'] || rawSpot['title'] || '';
    spot.desc = rawSpot['紹介文'] || rawSpot['説明'] || rawSpot['desc'] || '';
    spot.image = rawSpot['写真'] || rawSpot['画像'] || rawSpot['image'] || '';
    spot.image2 = rawSpot['写真2'] || rawSpot['画像2'] || rawSpot['image2'] || '';
    spot.image3 = rawSpot['写真3'] || rawSpot['画像3'] || rawSpot['image3'] || '';
    spot.image4 = rawSpot['写真4'] || rawSpot['画像4'] || rawSpot['image4'] || '';
    spot.area = rawSpot['エリア'] || rawSpot['area'] || '';
    spot.lat_lng_raw = rawSpot['lat_lng_raw'] || rawSpot['緯度経度'] || '';
    spot.map_url = rawSpot['googleマップのurl'] || rawSpot['googleマップのurl(共有リンク)'] || rawSpot['地図url'] || rawSpot['map_url'] || '';
    spot.hotel_url = rawSpot['hotel_url'] || rawSpot['ホテルurl'] || '';
    spot.author = rawSpot['ニックネーム'] || rawSpot['撮影者'] || rawSpot['author'] || rawSpot['nickname'] || '';

    if(spot.title) {
      spots.push(spot);
    }
  }

  return spots.map(spot => {
    let slug = spot.title.replace(/[\/\\]/g, '-');
    return {
      params: { slug: slug },
      props: { spot }, 
    };
  });
}

// 2. 各ページに渡されたデータを受け取る
const { spot } = Astro.props;

// GoogleドライブIDを抽出する関数
function getDriveId(urlOrId) {
  if (!urlOrId) return '';
  const match = urlOrId.toString().match(/[-\w]{25,}/);
  return match ? match[0] : '';
}

// メイン画像の処理
let rawImage = spot.image || '';
let firstImage = rawImage.includes(',') ? rawImage.split(',')[0].trim() : rawImage.trim();
let mainImageUrl = "https://placehold.co/600x800/e2e8f0/94a3b8?text=No+Image";
let mainDriveId = getDriveId(firstImage);

if (mainDriveId) {
  mainImageUrl = `https://lh3.googleusercontent.com/d/${mainDriveId}=w1200`;
} else if (firstImage.startsWith('http')) {
  mainImageUrl = firstImage;
}

// サブ画像（複数画像）のリストを作成
const subImages = [];
[spot.image2, spot.image3, spot.image4].forEach(img => {
  if (img) {
    const dId = getDriveId(img);
    if (dId) subImages.push({ id: dId, url: `https://lh3.googleusercontent.com/d/${dId}=w1200` });
  }
});

// Googleマップ用URL
let mapUrl = spot.map_url || '';
if(!mapUrl && spot.lat_lng_raw) {
   mapUrl = `https://www.google.com/maps/search/?api=1&query=${spot.lat_lng_raw}`;
}

// ホテル用URL
const defaultHotelUrl = "https://a.r10.to/hRIwm0";
const hotelUrl = (spot.hotel_url && spot.hotel_url.trim() !== "") ? spot.hotel_url.trim() : defaultHotelUrl;

// エリアの表示名
const areaLabels = {
  'all': 'ぜんぶ', 'mihara': '三原市街', 'daiwa': '大和', 'kui': '久井', 'hongo': '本郷', 'sagi': '佐木島'
};
const displayArea = areaLabels[spot.area] || spot.area || '三原市';
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  
  <title>{spot.title} | 三原市まち歩き - PHOTO MAP</title>
  <meta name="description" content={spot.desc}>
  
  <meta property="og:type" content="article">
  <meta property="og:title" content={`${spot.title} | PHOTO MAP`}>
  <meta property="og:description" content={spot.desc}>
  <meta property="og:image" content={mainImageUrl}>
  <meta name="twitter:card" content="summary_large_image">

  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <style>
    body { 
      font-family: 'Zen Maru Gothic', sans-serif; 
      color: #1a1a1a; 
      background-color: #f1f5f9; 
      word-break: break-all;
    }
    .serif-custom { font-family: 'Noto Serif JP', serif; }
    /* 横スクロールギャラリー用 */
    .gallery-container {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none; /* Firefox */
    }
    .gallery-container::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
    .gallery-item {
      flex: 0 0 100%;
      scroll-snap-align: start;
    }
  </style>

  <script is:inline>
    function handleFallbackErr(img, driveId) {
      if (!img || !driveId) return;
      const step = parseInt(img.dataset.fStep || '0');
      if (step === 0) {
        img.dataset.fStep = '1';
        img.src = 'https://drive.google.com/uc?export=view&id=' + driveId;
      } else if (step === 1) {
        img.dataset.fStep = '2';
        img.src = 'https://drive.google.com/thumbnail?id=' + driveId + '&sz=w1000';
      } else {
        img.onerror = null;
        img.src = 'https://placehold.co/600x800/e2e8f0/94a3b8?text=Image+Blocked';
      }
    }
  </script>
</head>
<body>
  
  <nav class="bg-white/90 backdrop-blur-md border-b border-gray-200 px-4 py-3 sticky top-0 z-50 flex items-center justify-between shadow-sm">
      <a href="/#gallery" class="text-[#004098] font-bold text-xs sm:text-sm flex items-center gap-2 hover:opacity-70 transition">
        <i class="fa-solid fa-arrow-left"></i> マップへ戻る
      </a>
      <div class="text-[10px] sm:text-xs font-bold text-gray-400 tracking-widest uppercase">Mihara Rediscover</div>
  </nav>

  <main class="max-w-3xl mx-auto bg-white min-h-screen shadow-md pb-24">
    
    <!-- ギャラリー部分（複数画像対応） -->
    <div class="relative w-full bg-[#f8f9fa]">
        <div class="gallery-container w-full h-[60vh] sm:h-[80vh]">
            <!-- メイン画像 -->
            <div class="gallery-item h-full flex items-center justify-center relative">
                <img 
                    src={mainImageUrl} 
                    alt={spot.title} 
                    class="w-full h-full object-contain" 
                    data-f-step="0" 
                    onerror={`handleFallbackErr(this, '${mainDriveId}')`} 
                />
            </div>
            <!-- サブ画像 -->
            {subImages.map((img, index) => (
                <div class="gallery-item h-full flex items-center justify-center relative bg-[#f1f5f9]">
                    <img 
                        src={img.url} 
                        alt={`${spot.title} - 写真${index + 2}`} 
                        class="w-full h-full object-contain" 
                        data-f-step="0" 
                        onerror={`handleFallbackErr(this, '${img.id}')`} 
                    />
                </div>
            ))}
        </div>
        
        <!-- 画像が複数ある場合はスワイプ案内を表示 -->
        {subImages.length > 0 && (
            <div class="absolute bottom-4 right-4 bg-black/50 text-white text-[10px] font-bold px-3 py-1.5 rounded-full flex items-center gap-2 backdrop-blur-sm">
                <i class="fa-solid fa-arrows-left-right"></i> スワイプして写真を見る
            </div>
        )}
        
        <div class="absolute top-4 left-4 bg-[#004098]/90 text-white text-[10px] font-bold px-3 py-1.5 rounded flex items-center gap-1.5 shadow-lg z-10">
            <i class="fa-solid fa-location-dot"></i> {displayArea}
        </div>
    </div>
    
    <div class="px-6 sm:px-10 py-8 sm:py-12">
       
       <h1 class="text-2xl sm:text-3xl font-bold text-[#004098] serif-custom mb-8 leading-relaxed border-b-2 border-blue-50 pb-6 mt-4">
           {spot.title}
       </h1>
       
       <div id="desc-container" class="text-gray-700 leading-loose text-sm sm:text-base whitespace-pre-line mb-12">
         {spot.desc}
       </div>
       <script is:inline>
         const descEl = document.getElementById('desc-container');
         if (descEl) {
           const urlRegex = /(https?:\/\/[^\s<]+)/g;
           descEl.innerHTML = descEl.innerHTML.replace(urlRegex, function(url) {
             return `<a href="${url}" target="_blank" rel="noopener noreferrer" style="color: #004098; text-decoration: underline;">${url}</a>`;
           });
         }
       </script>

       <!-- アクションボタン群 -->
       <div class="space-y-4">
           {mapUrl && (
             <a href={mapUrl} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full border border-blue-900 text-blue-900 font-bold text-xs py-4 rounded hover:bg-blue-50 transition">
               <i class="fa-solid fa-map-location-dot text-lg"></i> この場所をGoogleマップで見る
             </a>
           )}

           <a href={hotelUrl} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full text-white font-bold text-xs py-4 rounded hover:opacity-90 transition shadow-md" style="background: linear-gradient(to right, #1a2a6c, #11998e);">
             <i class="fa-solid fa-bed text-lg"></i> 周辺のホテル・宿を探す
           </a>
       </div>
       
       <div class="mt-16 pt-8 border-t border-dashed border-gray-200 flex justify-between items-center text-[10px] sm:text-xs font-bold text-gray-400 tracking-widest uppercase">
         <span>Photo by {spot.author || '管理者'}</span>
         <span>Share the Charm</span>
       </div>
       
    </div>
  </main>

</body>
</html>