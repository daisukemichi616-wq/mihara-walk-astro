                    { opacity: 1, filter: 'blur(0px)', scale: 1, duration: 2.5, ease: "power2.out", delay: 0.3 }
                );
                
                gsap.fromTo(heroTitle, 
                    { opacity: 0, filter: 'blur(15px)', y: 10 }, 
                    { opacity: 1, filter: 'blur(0px)', y: 0, duration: 3, ease: "power2.out", delay: 0.8 }
