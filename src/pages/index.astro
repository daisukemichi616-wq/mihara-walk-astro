        function initOpendataMap() {
            if (opendataMapInstance) return;
            const mapEl = document.getElementById('opendata-map');
            if(!mapEl) return;
            
            opendataMapInstance = L.map('opendata-map', { scrollWheelZoom: false }).setView([34.4005, 133.0830], 14);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { attribution: '© OSM', subdomains: 'abcd' }).addTo(opendataMapInstance);
            opendataMapInstance.once('focus', function() { opendataMapInstance.scrollWheelZoom.enable(); });

            toiletMarkersGroup = L.markerClusterGroup({ 
                showCoverageOnHover: false, 
                maxClusterRadius: 40,
                iconCreateFunction: function(cluster) {
                    return L.divIcon({
                        html: `<div style="background-color:rgba(59, 130, 246, 0.9); color:white; border-radius:50%; width:34px; height:34px; display:flex; align-items:center; justify-content:center; font-weight:bold; box-shadow:0 2px 5px rgba(0,0,0,0.3); border: 2px solid white; font-size:12px;">${cluster.getChildCount()}</div>`,
                        className: 'custom-toilet-cluster',
                        iconSize: L.point(34, 34)
                    });
                }
            });
            opendataMapInstance.addLayer(toiletMarkersGroup);

            const toiletIcon = L.divIcon({
                className: 'custom-toilet-icon',
                html: '<div style="background-color:#3b82f6; color:white; border-radius:50%; width:28px; height:28px; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,0.2); border: 2px solid white;"><i class="fa-solid fa-restroom text-[12px]"></i></div>',
                iconSize: [28, 28],
                iconAnchor: [14, 14]
            });

            try {
                const errorStatusStr = document.getElementById('toilet-error-status')?.textContent;
                const isError = errorStatusStr === "true";
                
                if(!isError) {
                    const spotsStr = document.getElementById('toilet-data-json')?.textContent;
                    if(spotsStr) {
                        const spots = JSON.parse(spotsStr);
                        spots.forEach(st => {
                            const marker = L.marker([st.lat, st.lng], { icon: toiletIcon })
                             .bindPopup(`<div class="text-[11px] font-bold text-[#004098] leading-tight mb-1">${escapeHtml(st.name)}</div><div class="text-[9px] text-gray-500">お出かけオアシススポット</div>`);
                            
                            toiletMarkersGroup.addLayer(marker);
                        });
                    }
                }
            } catch(e) {
                console.error("Map data parse error:", e);
            }
        }

        function initAnimations() {
            gsap.registerPlugin(ScrollTrigger);

            const heroLabel = document.getElementById('hero-label');
            const heroTitle = document.getElementById('hero-title');

            if (heroLabel && heroTitle) {
                gsap.fromTo(heroLabel, 
                    { opacity: 0, filter: 'blur(10px)', scale: 1.1 }, 
                    { opacity: 1, filter: 'blur(0px)', scale: 1, duration: 2.5, ease: "power2.out", delay: 0.3 }
                );
                
                gsap.fromTo(heroTitle, 
                    { opacity: 0, filter: 'blur(15px)', y: 10 }, 
                    { opacity: 1, filter: 'blur(0px)', y: 0, duration: 3, ease: "power2.out", delay: 0.8 }
                );
                
                gsap.fromTo('.reveal-on-load', 
                    { opacity: 0, y: 20 },
                    { opacity: 1, y: 0, duration: 2, ease: "power2.out", delay: 1.2 }
                );

                setTimeout(() => {
                    document.querySelectorAll('.count-up').forEach(el => {
                        const endVal = parseInt(el.getAttribute('data-val'), 10) || 0;
                        if (endVal === 0) return; 
                        const obj = { val: 0 };
                        
                        gsap.to(obj, {
                            val: endVal,
                            duration: 3,
                            ease: "power2.out",
                            onUpdate: () => {
                                el.innerHTML = Math.round(obj.val).toLocaleString();
                            }
                        });
                    });
                }, 1000);

                gsap.to('.hero-content', {
                    y: "40%", 
                    opacity: 0, 
                    scrollTrigger: {
                        trigger: '.hero-view',
                        start: "top top",
                        end: "bottom top",
                        scrub: true
                    }
                });
                
