        .tab-item { padding: 22px 16px; font-size: 0.85rem; font-weight: 700 !important; color: #9ca3af; border-bottom: 4px solid transparent; cursor: pointer; }
        .tab-item.active { color: var(--palette-blue); border-bottom-color: var(--palette-blue); }
        @media (min-width: 640px) { .tab-flex { justify-content: center; } .tab-item { padding: 22px 18px; } }
        
        .view-switch { display: inline-flex; background: #f1f5f9; padding: 4px; border-radius: 50px; margin-bottom: 20px; transition: all 0.5s ease; }
        .view-btn { padding: 8px 24px; border-radius: 40px; font-size: 11px; font-weight: 700; cursor: pointer; transition: all 0.3s; color: #64748b; display: flex; align-items: center; }
        .view-btn.active { background: white; color: var(--palette-blue); box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        
        .photo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: #ffffff; padding: 1.5px; }
        @media (min-width: 768px) { .photo-grid { grid-template-columns: repeat(4, 1fr); gap: 2px; padding: 2px; } }
        
        .photo-item { position: relative; aspect-ratio: 1/1; background: #f3f4f6; overflow: hidden; cursor: pointer; display: block; text-decoration: none; border-radius: 0; box-shadow: none; }
        .photo-item img { width: 100%; height: 100%; object-fit: cover; object-position: top center; transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), filter 0.8s ease; }
        
        .photo-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 80%); opacity: 0; transition: opacity 0.6s ease; display: flex; flex-direction: column; justify-content: flex-end; padding: 10px; pointer-events: none; }
        .photo-overlay span { transform: translateY(15px); opacity: 0; transition: transform 0.6s cubic-bezier(0.215, 0.61, 0.355, 1), opacity 0.6s ease; }
        
        /* PCのホバー時とスマホのタップ時の両方でアニメーションを発動 */
        .photo-item:hover img, .photo-item:active img { transform: scale(1.08) rotate(1.5deg); filter: brightness(1.05); }
        .photo-item:hover .photo-overlay, .photo-item:active .photo-overlay { opacity: 1; }
        .photo-item:hover .photo-overlay span, .photo-item:active .photo-overlay span { transform: translateY(0); opacity: 1; }
        .photo-item:hover .photo-overlay span:nth-child(2), .photo-item:active .photo-overlay span:nth-child(2) { transition-delay: 0.05s; }

        @media (hover: none) {
            .photo-item.in-view:not(:active) .photo-overlay { opacity: 1; transition-delay: 0.1s; }
            .photo-item.in-view:not(:active) .photo-overlay span { transform: translateY(0); opacity: 1; transition-delay: 0.3s; }
            .photo-item.in-view:not(:active) .photo-overlay span:nth-child(2) { transition-delay: 0.4s; }
        }
        
        #map-container { height: 60vh; min-height: 500px; width: 100%; z-index: 1; display: none; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border: 1px solid var(--border-soft); margin-top: 15px; }
        #map-container.active { display: block; }
        
        .leaflet-popup-content-wrapper { border-radius: 8px; overflow: hidden; padding: 0; box-shadow: 0 10px 25px rgba(0,0,0,0.15); }
        .leaflet-popup-content { margin: 0; width: 220px !important; }
        .popup-img-wrap { width: 100%; height: 130px; overflow: hidden; position: relative; background: #f3f4f6; }
        .popup-img { width: 100%; height: 100%; object-fit: cover; }
        .popup-info { padding: 12px; background: white; transition: background 0.5s ease; }
        .popup-title { font-size: 13px; font-weight: bold; color: var(--palette-blue); margin-bottom: 2px; line-height: 1.4; font-family: 'Noto Serif JP', serif !important; }
        .popup-area { font-size: 9px; color: #999; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 4px; display: block; }
        .popup-more { font-size: 10px; color: var(--palette-blue); display: flex; align-items: center; justify-content: flex-end; gap: 4px; font-weight: 700; margin-top: 5px; }
        .marker-cluster-small, .marker-cluster-medium, .marker-cluster-large { background-color: rgba(0, 64, 152, 0.2) !important; }
        .marker-cluster-small div, .marker-cluster-medium div, .marker-cluster-large div { background-color: var(--palette-blue) !important; color: #fff !important; font-family: 'Zen Maru Gothic', sans-serif !important; font-weight: 900 !important; box-shadow: 0 4px 10px rgba(0, 64, 152, 0.3); }
        
        .horizontal-scroll-container {
            display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 8px;
            padding: 10px 0 5px 0; 
            margin-left: -24px; margin-right: -24px; padding-left: 20px; padding-right: 20px; 
            scrollbar-width: none; cursor: grab; scroll-behavior: smooth;
        }
        .horizontal-scroll-container::-webkit-scrollbar { display: none; }
        .horizontal-scroll-container.active { cursor: grabbing; }
        
        .local-card-horizontal {
            flex: none;
            width: calc((100vw - 56px) / 3); 
            scroll-snap-align: start;
            display: flex; flex-direction: column; background: #fff;
            border: 2px solid transparent; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease; user-select: none;
            text-decoration: none; color: inherit; -webkit-tap-highlight-color: transparent;
        }
        .local-card-horizontal:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,64,152,0.08); }
        .horizontal-scroll-container.active .local-card-horizontal { transition: none; transform: none; }
        .local-card-horizontal.active-card { border-color: var(--palette-blue); box-shadow: 0 8px 20px rgba(0,64,152,0.15); }
        @media (min-width: 640px) {
            .local-card-horizontal { width: 180px; }
            .horizontal-scroll-container { margin-left: 0; margin-right: 0; padding-left: 0; padding-right: 0; gap: 16px; }
        }
        @media (min-width: 1024px) { 
            .local-card-horizontal { width: 220px; } 
        }

        .local-card-img-wrap { position: relative; width: 100%; aspect-ratio: 3/4; background: #f1f5f9; overflow: hidden; pointer-events: none; }
        .local-card-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; pointer-events: none; }
        .local-card-horizontal:hover .local-card-img-wrap img { transform: scale(1.05); }
        .local-tag-badge { position: absolute; top: 6px; left: 6px; background: rgba(0,64,152,0.9); color: white; font-size: 8px; font-weight: 700; padding: 3px 6px; border-radius: 4px; z-index: 2; display: flex; align-items: center; gap: 2px; box-shadow: 0 2px 5px rgba(0,0,0,0.2); }
        
        .local-card-content { flex: 1; padding: 8px; display: flex; flex-direction: column; justify-content: flex-start; pointer-events: none; }
        .local-card-title { font-size: 0.75rem; font-weight: 700; color: var(--palette-blue); margin-bottom: 4px; font-family: 'Noto Serif JP', serif !important; line-height: 1.3; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
        .local-card-desc { font-size: 0.6rem; font-weight: 500; color: var(--text-sub); line-height: 1.4; margin-bottom: 6px; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
        .local-area { font-size: 8px; font-weight: 700; color: #9ca3af; letter-spacing: 0.05em; text-transform: uppercase; pointer-events: none; }
        
        .local-read-link {
            display: flex; align-items: center; justify-content: flex-end; gap: 6px;
            font-size: 9px; font-weight: 700; color: var(--palette-blue); text-decoration: none;
            margin-top: 8px; position: relative; z-index: 10; cursor: pointer;
        }
        .local-read-link .read-text { position: relative; padding-bottom: 2px; }
        .local-read-link .read-text::after {
            content: ''; position: absolute; left: 0; bottom: 0; width: 0%; height: 1px;
            background-color: var(--palette-blue); transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .local-read-link:hover .read-text::after, .local-read-link:active .read-text::after { width: 100%; }
        
        .local-read-link .read-icon {
            display: flex; align-items: center; justify-content: center;
            width: 24px; height: 24px; border-radius: 50%;
            background: var(--palette-sky); color: var(--palette-blue);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); overflow: hidden;
        }
        .local-read-link:hover .read-icon, .local-read-link:active .read-icon {
            background: var(--palette-blue); color: #fff;
            transform: scale(1.1); box-shadow: 0 4px 10px rgba(0,64,152,0.2);
        }
        
        .local-read-link:hover .read-icon i, .local-read-link:active .read-icon i { 
            animation: arrow-fly 0.5s ease forwards; 
        }
        @keyframes arrow-fly {
            0% { transform: translateX(0); }
            49% { transform: translateX(20px); opacity: 0; }
            50% { transform: translateX(-20px); opacity: 0; }
            100% { transform: translateX(0); opacity: 1; }
        }
        
        .scroll-dots-container {
            display: flex; justify-content: center; align-items: center; gap: 6px;
            padding-top: 10px; padding-bottom: 20px;
        }
        .scroll-dot {
            width: 5px; height: 5px; border-radius: 50%; background: #cbd5e1;
            transition: all 0.3s ease;
        }
        .scroll-dot.active {
            background: var(--palette-blue); width: 14px; border-radius: 4px;
        }

        #local-map-container { height: 45vh; min-height: 350px; width: calc(100% + 48px); margin-left: -24px; border-radius: 0; border-top: 1px solid var(--border-soft); border-bottom: 1px solid var(--border-soft); border-left: none; border-right: none; z-index: 1; box-shadow: 0 8px 25px rgba(0,0,0,0.03); display: none; }
        @media (min-width: 640px) { #local-map-container { width: 100%; margin-left: 0; border-radius: 12px; border: 1px solid var(--border-soft); height: 50vh; min-height: 400px; } }
        @media (min-width: 1024px) { #local-map-container { height: 60vh; min-height: 500px; } }
        
        .count-up { font-variant-numeric: tabular-nums; }

        .h2-one-line { font-size: 1.6rem; font-weight: 700 !important; margin-bottom: 50px; line-height: 1.2; text-align: center; white-space: nowrap; letter-spacing: -0.07em; color: var(--palette-blue); }
        .insta-cta-box { margin-top: 60px; padding: 40px 20px; background: #fff; border: 2px dashed var(--palette-blue-light); border-radius: 20px; display: flex; flex-direction: column; align-items: center; gap: 20px; }
        .insta-btn-final { display: flex; align-items: center; justify-content: center; gap: 10px; background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: white !important; padding: 18px 45px; border-radius: 100px; font-weight: 700 !important; text-decoration: none; font-size: 1rem; box-shadow: 0 10px 25px rgba(220, 39, 67, 0.25); white-space: nowrap; }
        
        .bottom-view-container { position: relative; width: 100%; height: auto; min-height: 450px; aspect-ratio: 4/5; overflow: hidden; border-top: none; background: #f3f4f6; }
        @media (min-width: 640px) { .bottom-view-container { aspect-ratio: 16/7; } }
        .bottom-view-container img { position: absolute; top: -15%; left: 0; width: 100%; height: 130%; object-fit: cover; z-index: 1; transform-origin: center; }
        
        .bottom-view-overlay { position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding-top: 50px; }
        .floating-badge { background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); padding: 20px 35px; text-align: center; border: 1px solid rgba(255,255,255,0.3); border-radius: 4px; }
        .footer-main { text-align: center; background-color: #fff; padding: 60px 20px 60px 20px; transition: background-color 0.5s ease; }
        .footer-copy { font-size: 9px; font-weight: 700 !important; color: #9ca3af; letter-spacing: 0.3em; margin-bottom: 12px; text-transform: uppercase; }
        .footer-produced { font-size: 8px; font-weight: 500 !important; color: #cbd5e1; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; }

        .event-card { display: flex; flex-direction: column; background: white; border: 1px solid var(--border-soft); border-radius: 12px; padding: 20px; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0,64,152,0.02); text-decoration: none; color: inherit; gap: 15px; }
        @media (min-width: 640px) { .event-card { flex-direction: row; align-items: center; } }
        .event-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,64,152,0.08); border-color: var(--palette-blue-light); }
        .event-date-box { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--palette-sky); border: 1px solid var(--palette-blue-light); border-radius: 8px; padding: 12px 10px; width: 100%; text-align: center; color: var(--palette-blue); }
        @media (min-width: 640px) { .event-date-box { width: 120px; } }
        .event-content-box { flex: 1; display: flex; flex-direction: column; justify-content: center; min-width: 0; }
        
        .lang-jp, .lang-en { display: none; }
        body.is-jp .lang-jp { display: inline; }
        body.is-jp div.lang-jp, body.is-jp p.lang-jp { display: block; }
        body.is-en .lang-en { display: inline; }
        body.is-en div.lang-en, body.is-en p.lang-en { display: block; }

        /* ▼ 追加：視覚的魅力を高めるCSSアニメーション ▼ */
        /* SVGのパス自体を1.3倍に横に広げておき、端が切れない状態でゆったり動かす */
        @keyframes wave-sway-1 {
            0%, 100% { transform: scaleX(1.3) translate(-2%, 2px); }
            50% { transform: scaleX(1.3) translate(2%, -2px); }
        }
        @keyframes wave-sway-2 {
            0%, 100% { transform: scaleX(1.3) translate(2%, -2px); }
            50% { transform: scaleX(1.3) translate(-2%, 2px); }
        }
        @keyframes wave-sway-3 {
            0%, 100% { transform: scaleX(1.3) translate(-1%, 0px); }
            50% { transform: scaleX(1.3) translate(1%, 3px); }
        }
        
        svg.wave-animated { 
            overflow: visible; /* パスがはみ出ても表示させる */
        }
        
        .wave-animated path { 
            will-change: transform; 
            transform-origin: center bottom; 
            transform-box: fill-box; /* ★ これが重要：SVGパスのボックスを基準に変形させる */
        }
        .wave-animated path:nth-child(1) { animation: wave-sway-1 6s ease-in-out infinite; opacity: 0.5; }
        .wave-animated path:nth-child(2) { animation: wave-sway-2 8s ease-in-out infinite; opacity: 0.7; }
        .wave-animated path:nth-child(3) { animation: wave-sway-3 10s ease-in-out infinite; opacity: 1; }

        .btn-shine { position: relative; overflow: hidden; }
        .btn-shine::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%);
            transform: skewX(-25deg); animation: shine 3s infinite; z-index: 1; /* 秒数を早めて分かりやすく */
        }
        @keyframes shine {
            0% { left: -100%; }
            20% { left: 200%; }
            100% { left: 200%; }
        }

        .floating-element { animation: float 4s ease-in-out infinite; } /* こちらも少し早める */
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-12px); }
            100% { transform: translateY(0px); }
        }
        /* ▲ ここまで追加 ▲ */
    </style>
</head>
