        let weatherDataCache = null;
        async function fetchWeather() {
            try {
                const lat = 34.3964; const lng = 133.0781;
                const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true&daily=sunrise,sunset,weathercode,temperature_2m_max,temperature_2m_min&timezone=Asia%2FTokyo`;
                const response = await fetch(url);
                if (!response.ok) throw new Error('Weather fetch failed');
                const data = await response.json();
                updateWeatherUI(data);
            } catch (e) {
                console.error('Weather API Error:', e);
                const tempEl = document.getElementById('weather-temp-text');
                if (tempEl) tempEl.textContent = '--°C';
            }
        }

        function updateWeatherUI(data) {
            if (data) weatherDataCache = data;
            else data = weatherDataCache;
            if (!data) return;

            try {
                const current = data.current_weather;
                const daily = data.daily;
                const currentInfo = getWeatherInfo(current.weathercode, currentLang);

                const mainIcon = document.getElementById('weather-main-icon');
                if(mainIcon) mainIcon.className = `fa-solid ${currentInfo.iconClass} text-lg`;
                
                const tempText = document.getElementById('weather-temp-text');
                if(tempText) tempText.textContent = `${current.temperature}°C`;

                const formatTime = (date) => `${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}`;
                const sunsetStr = formatTime(new Date(daily.sunset[0]));

                let magicHourPreText = currentLang === 'en' ? 'Sunset: ' : '夕焼け: ';
                
                const magicText = document.getElementById('magic-hour-text');
                if(magicText) magicText.textContent = magicHourPreText + sunsetStr;

                const weeklyList = document.getElementById('weekly-forecast-list');
                if(weeklyList) {
                    weeklyList.innerHTML = '';
                    for(let i = 0; i < 7; i++) {
                        const dObj = new Date(daily.time[i]);
                        const dayJp = ['日', '月', '火', '水', '木', '金', '土'][dObj.getDay()];
                        const dayEn = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][dObj.getDay()];
                        const dayLabel = currentLang === 'en' ? dayEn : dayJp;
                        const maxT = Math.round(daily.temperature_2m_max[i]);
                        const minT = Math.round(daily.temperature_2m_min[i]);
                        const wInfo = getWeatherInfo(daily.weathercode[i], currentLang);
                        
                        const dayEl = document.createElement('div');
                        dayEl.className = "flex flex-col items-center flex-1 min-w-[42px]";
                        dayEl.innerHTML = `
                            <span class="text-[10px] text-gray-400 font-bold mb-1.5 weekly-day-label">${i === 0 ? (currentLang === 'en' ? 'Today' : '今日') : dayLabel}</span>
                            <i class="fa-solid ${wInfo.iconClass} text-[15px] mb-1.5"></i>
                            <div class="text-[9px] font-bold flex gap-1.5 mt-auto">
                                <span class="text-red-400">${maxT}°</span><span class="text-blue-500">${minT}°</span>
                            </div>
                        `;
                        weeklyList.appendChild(dayEl);
                    }
                }
            } catch(e) {
                console.warn('Weather UI Error:', e);
            }
        }

        function getWeatherInfo(code, lang) {
            let iconClass = 'fa-cloud text-gray-400';
            if (code === 0) { iconClass = 'fa-sun text-orange-500'; }
            else if (code === 1 || code === 2) { iconClass = 'fa-cloud-sun text-orange-400'; }
            else if (code === 3) { iconClass = 'fa-cloud text-gray-400'; }
            else if (code === 45 || code === 48) { iconClass = 'fa-smog text-gray-400'; }
            else if (code >= 51 && code <= 67) { iconClass = 'fa-umbrella text-blue-500'; }
            else if (code >= 71 && code <= 77) { iconClass = 'fa-snowflake text-blue-300'; }
            else if (code >= 80 && code <= 82) { iconClass = 'fa-cloud-showers-heavy text-blue-600'; }
            else if (code >= 95) { iconClass = 'fa-bolt text-yellow-500'; }
            return { iconClass };
        }

        window.toggleWeeklyWeather = function() {
            const container = document.getElementById('weekly-weather-container');
            const icon = document.getElementById('weekly-toggle-icon');
            if (container && icon) {
                if (container.style.maxHeight && container.style.maxHeight !== '0px') {
                    container.style.maxHeight = '0px'; container.style.opacity = '0'; icon.style.transform = 'rotate(0deg)';
                } else {
                    container.style.maxHeight = '150px'; container.style.opacity = '1'; icon.style.transform = 'rotate(180deg)';
                }
            }
        };

        function updateUI() {
            const mode = 'normal';
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (i18nData[key] && i18nData[key][mode] && i18nData[key][mode][currentLang]) {
                    el.innerHTML = i18nData[key][mode][currentLang];
                }
            });
            document.querySelectorAll('.tab-item').forEach(el => {
                const area = el.getAttribute('data-area');
                if (areaLabels[area]) el.textContent = areaLabels[area][currentLang];
            });
            const langTextEl = document.getElementById('lang-text');
            if (langTextEl) langTextEl.textContent = currentLang === 'jp' ? 'EN' : 'JP';

            if (currentLang === 'en') {
                document.body.classList.add('lang-en');
                document.body.classList.remove('lang-jp');
            } else {
                document.body.classList.add('lang-jp');
                document.body.classList.remove('lang-en');
            }

            updateWeatherUI();
            if(spotsData.length > 0) render(currentActiveArea);
            renderLocalInsights(); 
            renderEvents(); 
        }

        window.toggleLanguage = function() {
            currentLang = currentLang === 'jp' ? 'en' : 'jp';
            localStorage.setItem('siteLang', currentLang); 
            updateUI();
        };

        function getLocalizedSpotField(spot, field) {
            const lang = currentLang;
            if (field === 'title') {
                if (lang === 'en') return spot.title_en || spot.title || 'Unknown Area';
                return spot.title || '名称未設定';
            }
            if (field === 'desc') {
                const def = lang === 'en' ? 'No description available.' : '紹介文はありません。';
                if (lang === 'en') return spot.desc_en || spot.desc || def;
                return spot.desc || def;
            }
            return '';
        }

        window.scrollToId = function(id) {
            const el = document.getElementById(id);
            if (el) window.scrollTo({ top: el.getBoundingClientRect().top + window.pageYOffset - 60, behavior: 'smooth' });
        };

        let currentSlide = 0;
        let slideInterval;
        function rotateSlides() {
            const slides = document.querySelectorAll('.slide');
            if (slides.length < 2) return;
            if (slideInterval) clearInterval(slideInterval);
            slideInterval = setInterval(() => {
                if (slides[currentSlide]) slides[currentSlide].classList.remove('active');
                currentSlide = (currentSlide + 1) % slides.length;
                if (slides[currentSlide]) slides[currentSlide].classList.add('active');
            }, 6000);
        }

        const CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vR0jkQnLXsIL33pmO60BCd0hIr_v5xh34cJ_IWAHkF0pTaj855pzicmNoVx6W8CPK3MEhlp-irodPSE/pub?gid=1232979489&single=true&output=csv";
        const LOCAL_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vTia8V00j15toSprtd2bQV4JWrZprRz7m_cf73IZla6KOu62wtunUjCrb9wKkyNthWep8TfDeT8HW2B/pub?gid=1467172273&single=true&output=csv";
        const EVENT_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQqAv0S9Shfo2bXUlTuP4jtkZ75D-wt4qCl-P_GOFYMu53peSOEwy7EhbUSUEeBi_T0jehNRIbgp91M/pub?output=csv";

        let spotsData = [];
        let localInsightsData = [];
        let eventsData = [];
        let localMapInstance = null;
        let localMarkersGroup = null;
        let localMarkersMap = {};
        
        const AREA_POSITIONS = { 'all': { lat: 34.4200, lng: 133.0800, zoom: 11 }, 'mihara': { lat: 34.4000, lng: 133.0800, zoom: 13 }, 'daiwa': { lat: 34.5300, lng: 132.9500, zoom: 12 }, 'kui': { lat: 34.5600, lng: 133.0500, zoom: 12 }, 'hongo': { lat: 34.4200, lng: 132.9200, zoom: 12 }, 'sagi': { lat: 34.3300, lng: 133.1100, zoom: 12 } };
        const ITEMS_PER_PAGE = 12;
        let currentFilteredData = [];
        let displayedCount = 0;
        let currentActiveArea = 'all';
        let mapInstance = null;
        let markersClusterGroup = null; 
        let currentViewMode = 'grid'; 

        const EVENTS_PER_PAGE = 10;
        let eventsDisplayedCount = 0;

        function getDriveId(urlOrId) {
            if (!urlOrId) return '';
            const match = urlOrId.toString().match(/[-\w]{25,}/);
            return match ? match[0] : '';
        }

        function getPrimaryImgUrl(driveId, urlOrId, size = 'w1000') {
            if (driveId) return `https://lh3.googleusercontent.com/d/${driveId}=${size}`;
            if (urlOrId && urlOrId.toString().startsWith('http')) return urlOrId.toString().replace('http://', 'https://');
            return '';
        }

        window.handleImgErr = function(img, driveId) {
            if (!img || !driveId) {
                if (img) { img.onerror = null; img.src = 'https://placehold.co/600x800/e2e8f0/94a3b8?text=No+Image'; }
                return;
            }
            const step = parseInt(img.dataset.fStep || '0');
            if (step === 0) {
                img.dataset.fStep = '1';
                img.src = `https://drive.google.com/uc?export=view&id=${driveId}`;
            } else if (step === 1) {
                img.dataset.fStep = '2';
                img.src = `https://drive.google.com/thumbnail?id=${driveId}&sz=w1000`;
            } else if (step === 2) {
                img.dataset.fStep = '3';
                img.src = `https://wsrv.nl/?url=https://drive.google.com/uc?export=view%26id=${driveId}`;
            } else {
                img.onerror = null; 
                img.src = 'https://placehold.co/600x800/e2e8f0/94a3b8?text=Image+Blocked';
            }
        };

        window.switchView = function(mode) {
            currentViewMode = mode;
            const gridWrap = document.getElementById('gallery-wrap');
            const mapContainer = document.getElementById('map-container');
            const btnGrid = document.getElementById('btn-view-grid');
            const btnMap = document.getElementById('btn-view-map');
            
            if (mode === 'grid') {
                if (gridWrap) gridWrap.style.display = 'block'; 
                if (mapContainer) mapContainer.classList.remove('active');
                if (btnGrid) btnGrid.classList.add('active'); 
                if (btnMap) btnMap.classList.remove('active');
            } else {
                if (gridWrap) gridWrap.style.display = 'none'; 
                if (mapContainer) mapContainer.classList.add('active');
                if (btnGrid) btnGrid.classList.remove('active'); 
                if (btnMap) btnMap.classList.add('active');
                if (!mapInstance) initMap(); else setTimeout(() => { mapInstance.invalidateSize(); }, 200);
                updateMapMarkers();
            }
        };

        function initMap() {
            const initPos = AREA_POSITIONS['all'];
            mapInstance = L.map('map-container').setView([initPos.lat, initPos.lng], initPos.zoom);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { attribution: '© OSM', subdomains: 'abcd', maxZoom: 19 }).addTo(mapInstance);
            markersClusterGroup = L.markerClusterGroup({ showCoverageOnHover: false, maxClusterRadius: 50, spiderfyOnMaxZoom: true });
            mapInstance.addLayer(markersClusterGroup);
        }

        function escapeHtml(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }
        
        function stripHtml(html) {
            let tmp = document.createElement("DIV");
            tmp.innerHTML = html;
            return tmp.textContent || tmp.innerText || "";
        }

        function updateMapMarkers() {
            if (!mapInstance || !markersClusterGroup) return;
            markersClusterGroup.clearLayers();
            let hasMarkers = false;

            currentFilteredData.forEach(spot => {
                if (spot.lat && spot.lng) {
                    const lat = parseFloat(spot.lat); const lng = parseFloat(spot.lng);
                    if (isNaN(lat) || isNaN(lng)) return;
                    hasMarkers = true;

                    const driveId = getDriveId(spot.image);
                    const imgUrl = getPrimaryImgUrl(driveId, spot.image, 'w500');
                    const areaLabel = areaLabels[spot.area] ? areaLabels[spot.area][currentLang] : (currentLang==='en'?'MIHARA':'三原');
                    
                    const displayTitle = escapeHtml(getLocalizedSpotField(spot, 'title'));
                    const slug = (spot.title || '').replace(/[\/\\]/g, '-');
                    
                    const popupContent = `
                        <a href="/spot/${slug}/" style="display:block; text-decoration:none; color:inherit;">
                            <div class="popup-img-wrap"><img src="${imgUrl}" class="popup-img" data-f-step="0" onerror="handleImgErr(this, '${driveId}')"></div>
                            <div class="popup-info">
                                <span class="popup-area">${areaLabel}</span>
                                <div class="popup-title">${displayTitle}</div>
                                <div class="popup-more">${currentLang === 'en' ? 'Details' : '詳細を見る'} <i class="fa-solid fa-chevron-right text-[8px] ml-1"></i></div>
                            </div>
                        </a>`;
                    markersClusterGroup.addLayer(L.marker([lat, lng]).bindPopup(popupContent));
                }
            });
            if (hasMarkers) mapInstance.fitBounds(markersClusterGroup.getBounds(), { padding: [50, 50], maxZoom: 15 });
            else { const set = AREA_POSITIONS[currentActiveArea] || AREA_POSITIONS['all']; mapInstance.setView([set.lat, set.lng], set.zoom); }
        }

        function render(filter) {
            currentActiveArea = filter; 
            const grid = document.getElementById('gallery-grid');
            const loadMoreArea = document.getElementById('load-more-area');
            const filtered = filter === 'all' ? [...spotsData] : spotsData.filter(s => s.area === filter);
            currentFilteredData = filtered.reverse();

            if (grid) grid.innerHTML = '';
            displayedCount = 0;

            if (currentFilteredData.length === 0) {
                if (grid) grid.innerHTML = `<div class="col-span-3 py-32 text-center text-[10px] font-bold text-gray-300 uppercase tracking-widest">${currentLang === 'en' ? 'No Items Found' : 'データがありません'}</div>`;
                if (loadMoreArea) loadMoreArea.classList.add('hidden');
            } else {
                loadMoreItems();
            }

            if (currentViewMode === 'map') updateMapMarkers();
        }

        const itemObserver = new IntersectionObserver((entries, obs) => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); obs.unobserve(e.target); }});
        }, { threshold: 0.25 });

        window.loadMoreItems = function() {
            const grid = document.getElementById('gallery-grid');
            const loadMoreArea = document.getElementById('load-more-area');
            if (!grid) return;

            const nextItems = currentFilteredData.slice(displayedCount, displayedCount + ITEMS_PER_PAGE);

            nextItems.forEach(spot => {
                const driveId = getDriveId(spot.image);
                const imgUrl = getPrimaryImgUrl(driveId, spot.image, 'w500');
                const areaName = areaLabels[spot.area] ? areaLabels[spot.area][currentLang] : (currentLang==='en'?'MIHARA':'三原');
                
                const slug = (spot.title || '').replace(/[\/\\]/g, '-');
                const item = document.createElement('a');
                item.href = `/spot/${slug}/`;
                item.className = 'photo-item block';
                
                const safeAlt = escapeHtml(getLocalizedSpotField(spot, 'title'));
                
                item.innerHTML = `
                    <img src="${imgUrl}" loading="lazy" alt="${safeAlt}" data-f-step="0" onerror="handleImgErr(this, '${driveId}')">
                    <div class="photo-overlay">
                        <span class="text-[9px] text-white font-bold tracking-widest uppercase mb-1">${areaName}</span>
                        <span class="text-sm text-white font-bold serif-custom drop-shadow-md">${safeAlt}</span>
                    </div>
                `;
                grid.appendChild(item);
                itemObserver.observe(item);
            });
            displayedCount += nextItems.length;
            if (loadMoreArea) {
                if (displayedCount < currentFilteredData.length) loadMoreArea.classList.remove('hidden');
                else loadMoreArea.classList.add('hidden');
            }
        };

        function initLocalMap() {
            if (localMapInstance) return;
            const initPos = AREA_POSITIONS['all'];
            localMapInstance = L.map('local-map-container', { scrollWheelZoom: false }).setView([initPos.lat, initPos.lng], initPos.zoom);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { attribution: '© OSM', subdomains: 'abcd', maxZoom: 19 }).addTo(localMapInstance);
            localMarkersGroup = L.markerClusterGroup({ showCoverageOnHover: false, maxClusterRadius: 50, spiderfyOnMaxZoom: true });
            localMapInstance.addLayer(localMarkersGroup);
            localMapInstance.once('focus', function() { localMapInstance.scrollWheelZoom.enable(); });
        }

        function renderLocalInsights() {
            const container = document.getElementById('local-scroll-container');
            const mapContainer = document.getElementById('local-map-container');
            if (!container) return;
            container.innerHTML = '';

            if (localInsightsData.length === 0) {
                container.innerHTML = `
                    <div class="w-full py-20 text-center bg-white rounded-xl border border-dashed border-gray-300 mx-6 sm:mx-0 flex flex-col items-center justify-center">
                        <i class="fa-solid fa-person-walking text-4xl text-gray-200 mb-4"></i>
                        <span class="text-[11px] font-bold text-gray-400 uppercase tracking-widest" data-i18n="local-empty">現在、お散歩コースを準備中です...</span>
                    </div>
                `;
                const el = container.querySelector('[data-i18n="local-empty"]');
                if (el && i18nData['local-empty']['normal'][currentLang]) {
                    el.innerHTML = i18nData['local-empty']['normal'][currentLang];
                }
                if (mapContainer) mapContainer.style.display = 'none';
                return;
            }

            if (mapContainer) mapContainer.style.display = 'block';
            if (!localMapInstance) initLocalMap();
            if (localMarkersGroup) localMarkersGroup.clearLayers();
            localMarkersMap = {};
            let hasMarkers = false;

            const observerOptions = { root: container, rootMargin: '0px', threshold: 0.8 };
            const cardObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const title = entry.target.dataset.title;
                        const marker = localMarkersMap[title];
                        
                        document.querySelectorAll('.local-card-horizontal').forEach(c => c.classList.remove('active-card'));
                        entry.target.classList.add('active-card');

                        if (marker) {
                            localMapInstance.setView(marker.getLatLng(), 15, { animate: true, duration: 0.5 });
                            marker.openPopup();
                        }
                    }
                });
            }, observerOptions);

            localInsightsData.forEach(spot => {
                const driveId = getDriveId(spot.image);
                const imgUrl = getPrimaryImgUrl(driveId, spot.image, 'w800');
                const lang = currentLang;
                const title = (lang === 'en' && spot.title_en) ? spot.title_en : spot.title;
                const desc = (lang === 'en' && spot.desc_en) ? spot.desc_en : spot.desc;
                
                const defaultTagJp = "👟 みはらさんぽ";
                const defaultTagEn = "👟 Mihara Walk";
                const tag = lang === 'en' ? (spot.tag_en || spot.tag || defaultTagEn) : (spot.tag || defaultTagJp);
                
                const areaLabel = areaLabels[spot.area] ? areaLabels[spot.area][lang] : (lang==='en'?'MIHARA':'三原');

                // ▼ 日付を安全な形式で取得する魔法 ▼
                const safeDate = spot.date ? escapeHtml(spot.date.split(' ')[0].replace(/\//g, '.')) : '';

                const slug = (spot.title || '').replace(/[\/\\]/g, '-');
                const card = document.createElement('a');
                card.href = `/local-log/${slug}/`;
                card.className = 'local-card-horizontal block';
                card.dataset.title = spot.title; 
                
                card.ondragstart = () => false;
                card.onclick = (e) => {
                    if (window.isDragged) {
                        e.preventDefault();
                    }
                };

                const safeAlt = escapeHtml(title);
                const safeDesc = stripHtml(desc);

                // ▼ カードの下部（footer）に日付を表示するようにしました！ ▼
                card.innerHTML = `
                    <div class="local-card-img-wrap">
                        <div class="local-tag-badge">${escapeHtml(tag)}</div>
                        <img src="${imgUrl}" loading="lazy" alt="${safeAlt}" data-f-step="0" onerror="handleImgErr(this, '${driveId}')">
                    </div>
                    <div class="local-card-content">
                        <h4 class="local-card-title">${safeAlt}</h4>
                        <p class="local-card-desc">${safeDesc}</p>
                        <div class="local-card-footer">
                            <div class="flex flex-col gap-1.5">
                                <span class="local-area"><i class="fa-solid fa-location-dot mr-1"></i> ${areaLabel}</span>
                                ${safeDate ? `<span class="text-[9px] text-gray-400 font-bold tracking-widest"><i class="fa-regular fa-clock mr-1"></i>${safeDate}</span>` : ''}
                            </div>
                            <span class="local-btn">${lang === 'en' ? 'Details' : '詳細を見る'} <i class="fa-solid fa-chevron-right text-[10px] ml-1"></i></span>
                        </div>
                    </div>
                `;
                container.appendChild(card);
                cardObserver.observe(card);

                if (spot.lat && spot.lng) {
                    const lat = parseFloat(spot.lat); const lng = parseFloat(spot.lng);
                    if (!isNaN(lat) && !isNaN(lng)) {
                        hasMarkers = true;
                        const popupImgUrl = getPrimaryImgUrl(driveId, spot.image, 'w500');
                        
                        const popupContent = `
                            <a href="/local-log/${slug}/" style="display:block; text-decoration:none; color:inherit;">
                                <div class="popup-img-wrap"><img src="${popupImgUrl}" class="popup-img" data-f-step="0" onerror="handleImgErr(this, '${driveId}')"></div>
                                <div class="popup-info">
                                    <span class="popup-area">${areaLabel}</span>
                                    <div class="popup-title">${safeAlt}</div>
                                    <div class="popup-more">${lang === 'en' ? 'Details' : '詳細を見る'} <i class="fa-solid fa-chevron-right text-[8px] ml-1"></i></div>
                                </div>
                            </a>`;
                        
                        if (localMarkersGroup) {
                            const marker = L.marker([lat, lng]).bindPopup(popupContent);
                            localMarkersGroup.addLayer(marker);
                            localMarkersMap[spot.title] = marker;
                        }
                    }
                }
            });

            if (hasMarkers && localMapInstance && localMarkersGroup) {
                setTimeout(() => {
                    localMapInstance.invalidateSize();
                    localMapInstance.fitBounds(localMarkersGroup.getBounds(), { padding: [30, 30], maxZoom: 14 });
                    const firstCard = container.querySelector('.local-card-horizontal');
                    if (firstCard) firstCard.classList.add('active-card');
                }, 300);
            }
        }

        function renderEvents(append = false) {
            const container = document.getElementById('events-container');
            const loadMoreArea = document.getElementById('event-load-more-area');
            if (!container) return;
            
            if (!append) {
                container.innerHTML = '';
                eventsDisplayedCount = 0;
            }

            if (eventsData.length === 0) {
                container.innerHTML = `
                    <div class="w-full py-16 text-center bg-gray-50 rounded-xl border border-dashed border-gray-200">
                        <i class="fa-regular fa-calendar-xmark text-3xl text-gray-300 mb-3"></i>
                        <div class="text-xs font-bold text-gray-400" data-i18n="event-empty">現在、予定されているイベントはありません。</div>
                    </div>
                `;
                const el = container.querySelector('[data-i18n="event-empty"]');
                if (el && i18nData['event-empty']['normal'][currentLang]) {
                    el.innerHTML = i18nData['event-empty']['normal'][currentLang];
                }
                if (loadMoreArea) loadMoreArea.classList.add('hidden');
                return;
            }

            const nextEvents = eventsData.slice(eventsDisplayedCount, eventsDisplayedCount + EVENTS_PER_PAGE);

            nextEvents.forEach(event => {
                const lang = currentLang;
                const title = (lang === 'en' && event.title_en) ? event.title_en : event.title;
                const desc = (lang === 'en' && event.desc_en) ? event.desc_en : event.desc;
                const dateStr = (lang === 'en' && event.date_str_en) ? event.date_str_en : event.date_str;

                const safeTitle = escapeHtml(title);
                
                let safeDesc = escapeHtml(desc).replace(/\n/g, '<br>');
                const urlRegex = /(https?:\/\/[^\s<]+)/g;
                safeDesc = safeDesc.replace(urlRegex, function(url) {
                    return `<a href="${url}" target="_blank" rel="noopener noreferrer" class="text-blue-500 underline" onclick="event.stopPropagation()">${url}</a>`;
                });

                const safeDate = escapeHtml(dateStr || '開催日未定');
                const linkUrl = event.url ? escapeHtml(event.url) : '#';
                
                const isLink = event.url && event.url.trim() !== '';
                const cardTag = isLink ? 'a' : 'div';
                const card = document.createElement(cardTag);
                
                if (isLink) {
                    card.href = linkUrl;
                    card.target = "_blank";
                    card.rel = "noopener noreferrer";
                }
                
                card.className = `event-card ${!isLink ? 'cursor-default hover:transform-none hover:shadow-[0_4px_15px_rgba(0,64,152,0.02)] hover:border-[var(--border-soft)]' : ''}`;

                card.innerHTML = `
                    <div class="event-date-box">
                        <i class="fa-regular fa-calendar text-xl mb-1.5 opacity-70"></i>
                        <span class="text-[12px] sm:text-[13px] font-bold leading-tight" style="word-break: keep-all;">${safeDate}</span>
                    </div>
                    <div class="event-content-box">
                        <h4 class="font-bold text-blue-900 text-[15px] sm:text-[17px] mb-2 leading-snug">${safeTitle}</h4>
                        <p class="text-xs text-gray-500 leading-relaxed mb-3">${safeDesc}</p>
                        <div class="mt-auto flex justify-end">
                            ${isLink 
                                ? `<span class="text-[10px] font-bold text-blue-500 flex items-center gap-1 hover:text-blue-700 transition">${lang === 'en' ? 'Details' : '詳細を見る'} <i class="fa-solid fa-arrow-up-right-from-square text-[9px] ml-0.5"></i></span>`
                                : `<span class="text-[10px] font-bold text-gray-300 flex items-center gap-1"><i class="fa-solid fa-link-slash text-[9px]"></i> ${lang === 'en' ? 'No Link' : 'リンクなし'}</span>`
                            }
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });

            eventsDisplayedCount += nextEvents.length;

            if (loadMoreArea) {
                if (eventsDisplayedCount < eventsData.length) {
                    loadMoreArea.classList.remove('hidden');
                } else {
                    loadMoreArea.classList.add('hidden');
                }
            }
        }

        window.loadMoreEvents = function() {
            renderEvents(true);
        };

        window.isDown = false;
        window.startX = 0;
        window.scrollLeft = 0;
        window.isDragged = false;
        
        window.addEventListener('DOMContentLoaded', () => {
            const scrollContainer = document.getElementById('local-scroll-container');
            if (scrollContainer) {
                scrollContainer.addEventListener('mousedown', (e) => {
                    window.isDown = true;
                    window.isDragged = false;
                    scrollContainer.classList.add('active');
                    scrollContainer.style.scrollSnapType = 'none'; 
                    window.startX = e.pageX - scrollContainer.offsetLeft;
                    window.scrollLeft = scrollContainer.scrollLeft;
                });

                scrollContainer.addEventListener('mouseleave', () => {
                    window.isDown = false;
                    scrollContainer.classList.remove('active');
                    scrollContainer.style.scrollSnapType = 'x mandatory';
                });

                scrollContainer.addEventListener('mouseup', () => {
                    window.isDown = false;
                    scrollContainer.classList.remove('active');
                    scrollContainer.style.scrollSnapType = 'x mandatory';
                    setTimeout(() => { window.isDragged = false; }, 50);
                });

                scrollContainer.addEventListener('mousemove', (e) => {
                    if (!window.isDown) return;
                    e.preventDefault();
                    const x = e.pageX - scrollContainer.offsetLeft;
                    const walk = (x - window.startX) * 1.5; 
                    if (Math.abs(walk) > 5) window.isDragged = true; 
                    scrollContainer.scrollLeft = window.scrollLeft - walk;
                });
            }
        });

        window.addEventListener('load', () => {
            fetchWeather();
            
            const urlParams = new URLSearchParams(window.location.search);
            const paramLang = urlParams.get('lang');
            const savedLang = localStorage.getItem('siteLang');
            
            if (paramLang === 'en' || paramLang === 'jp') {
                currentLang = paramLang;
                localStorage.setItem('siteLang', currentLang);
            } else if (savedLang === 'en' || savedLang === 'jp') {
                currentLang = savedLang;
            }
            
            updateUI();
            rotateSlides();

            if (typeof Papa !== 'undefined') {
                Papa.parse(CSV_URL, {
                    download: true, header: true, skipEmptyLines: true,
                    complete: function(results) {
                        try {
                            spotsData = results.data.map(row => {
                                const clean = {};
                                Object.keys(row).forEach(k => {
                                    if (!k) return; 
                                    let cleanKey = k.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase(); 
                                    clean[cleanKey] = (typeof row[k] === 'string') ? row[k].trim() : row[k];
                                });

                                if (!clean.title) clean.title = clean['スポット名'] || clean['タイトル'] || '';
                                if (!clean.desc) clean.desc = clean['紹介文'] || clean['説明'] || '';
                                if (!clean.image) clean.image = clean['写真'] || clean['画像'] || '';
                                if (!clean.area) clean.area = clean['エリア'] || '';

                                if (clean.lat_lng_raw) {
                                    const parts = String(clean.lat_lng_raw).split(',');
                                    if (parts.length >= 2) {
                                        clean.lat = parts[0].trim();
                                        clean.lng = parts[1].trim();
                                    }
                                }

                                if (!clean.map_url) clean.map_url = clean['googleマップのurl'] || clean['googleマップのurl(共有リンク)'] || clean['googleマップのurl（共有リンク）'] || clean['地図url'] || clean['googlemap'] || '';
                                return clean;
                            }).filter(s => s.title);
                            
                            render('all');
                        } catch(e) { console.warn('Data parse warning:', e); }
                    },
                    error: function(err) {
                        const grid = document.getElementById('gallery-grid');
                        if (grid) grid.innerHTML = '<div class="col-span-3 py-10 text-center text-xs text-red-400">データの読み込みに失敗しました。</div>';
                    }
                });

                if (LOCAL_CSV_URL && LOCAL_CSV_URL.startsWith("http")) {
                    Papa.parse(LOCAL_CSV_URL, {
                        download: true, header: true, skipEmptyLines: true,
                        complete: function(results) {
                            try {
                                localInsightsData = results.data.map(row => {
                                    const clean = {};
                                    Object.keys(row).forEach(k => {
                                        if (!k) return;
                                        let cleanKey = k.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase(); 
                                        clean[cleanKey] = (typeof row[k] === 'string') ? row[k].trim() : row[k];
                                    });

                                    if (!clean.title) clean.title = clean['スポット名'] || clean['タイトル'] || '';
                                    if (!clean.desc) clean.desc = clean['紹介文（パパママ目線）'] || clean['紹介文'] || clean['説明'] || '';
                                    if (!clean.image) clean.image = clean['写真'] || clean['画像'] || '';
                                    if (!clean.area) clean.area = clean['エリア'] || '';
                                    if (!clean.tag) clean.tag = clean['タグ'] || '';

                                    // ▼ スプレッドシートから「タイムスタンプ（日付）」を読み込む魔法 ▼
                                    if (!clean.date) clean.date = clean['タイムスタンプ'] || clean['日付'] || clean['date'] || '';

                                    if (clean.lat_lng_raw) {
                                        const parts = String(clean.lat_lng_raw).split(',');
                                        if (parts.length >= 2) {
                                            clean.lat = parts[0].trim();
                                            clean.lng = parts[1].trim();
                                        }
                                    }

                                    return clean;
                                }).filter(s => s.title); 
                                
                                // ▼ 最新順（一番新しいものが左にくる）に並び替え ▼
                                localInsightsData.reverse();
                                
                                renderLocalInsights();
                            } catch (e) { console.warn('Local Data parse warning:', e); }
                        },
                        error: function(err) {
                            localInsightsData = [];
                            renderLocalInsights(); 
                        }
                    });
                } else {
                    localInsightsData = [];
                    renderLocalInsights();
                }

                if (EVENT_CSV_URL && EVENT_CSV_URL.startsWith("http")) {
                    Papa.parse(EVENT_CSV_URL, {
                        download: true, header: true, skipEmptyLines: true,
                        complete: function(results) {
                            try {
                                const today = new Date();
                                today.setHours(0, 0, 0, 0); 

                                eventsData = results.data.map(row => {
                                    const clean = {};
                                    Object.keys(row).forEach(k => {
                                        if (!k) return; 
                                        let cleanKey = k.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase(); 
                                        clean[cleanKey] = (typeof row[k] === 'string') ? row[k].trim() : row[k];
                                    });

                                    if (!clean.title) clean.title = clean['イベント名'] || clean['タイトル'] || '';
                                    if (!clean.desc) clean.desc = clean['説明'] || clean['紹介文'] || '';
                                    
                                    if (!clean.title_en) clean.title_en = clean['title_en'] || '';
                                    if (!clean.desc_en) clean.desc_en = clean['desc_en'] || '';
                                    
                                    if (!clean.start_date) clean.start_date = clean['開始日'] || '';
                                    if (!clean.end_date) clean.end_date = clean['終了日'] || '';

                                    let autoDateStrJp = '';
                                    let autoDateStrEn = '';
                                    
                                    if (clean.start_date || clean.end_date) {
                                        const parseD = (str) => {
                                            if(!str) return null;
                                            const d = new Date(str.replace(/-/g, '/'));
                                            return isNaN(d.getTime()) ? null : d;
                                        };
                                        const sD = parseD(clean.start_date);
                                        const eD = parseD(clean.end_date);
                                        
                                        const currentYear = new Date().getFullYear();

                                        const fmtFullJp = (d) => {
                                            const yobi = ['日', '月', '火', '水', '木', '金', '土'][d.getDay()];
                                            return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日(${yobi})`;
                                        };
                                        const fmtJp = (d) => {
                                            const yobi = ['日', '月', '火', '水', '木', '金', '土'][d.getDay()];
                                            return `${d.getMonth() + 1}月${d.getDate()}日(${yobi})`;
                                        };

                                        const fmtFullEn = (d) => {
                                            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                                            const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                                            return `${months[d.getMonth()]} ${d.getDate()} ${d.getFullYear()} (${days[d.getDay()]})`;
                                        };
                                        const fmtEn = (d) => {
                                            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                                            const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                                            return `${months[d.getMonth()]} ${d.getDate()} (${days[d.getDay()]})`;
                                        };
                                        
                                        if (sD && eD) {
                                            if (sD.getTime() === eD.getTime()) {
                                                autoDateStrJp = sD.getFullYear() === currentYear ? fmtJp(sD) : fmtFullJp(sD);
                                                autoDateStrEn = sD.getFullYear() === currentYear ? fmtEn(sD) : fmtFullEn(sD);
                                            } else if (sD.getFullYear() === eD.getFullYear()) {
                                                autoDateStrJp = `${sD.getFullYear() === currentYear ? fmtJp(sD) : fmtFullJp(sD)}〜${fmtJp(eD)}`;
                                                autoDateStrEn = `${sD.getFullYear() === currentYear ? fmtEn(sD) : fmtFullEn(sD)} - ${fmtEn(eD)}`;
                                            } else {
                                                autoDateStrJp = `${fmtFullJp(sD)}〜${fmtFullJp(eD)}`;
                                                autoDateStrEn = `${fmtFullEn(sD)} - ${fmtFullEn(eD)}`;
                                            }
                                        } else if (sD) {
                                            autoDateStrJp = sD.getFullYear() === currentYear ? fmtJp(sD) : fmtFullJp(sD);
                                            autoDateStrEn = sD.getFullYear() === currentYear ? fmtEn(sD) : fmtFullEn(sD);
                                        } else if (eD) {
                                            autoDateStrJp = `〜${eD.getFullYear() === currentYear ? fmtJp(eD) : fmtFullJp(eD)}`;
                                            autoDateStrEn = `Until ${eD.getFullYear() === currentYear ? fmtEn(eD) : fmtFullEn(eD)}`;
                                        }
                                    }

                                    if (!clean.date_str) clean.date_str = clean['表示用日付'] || clean['日付'] || autoDateStrJp || '';
                                    if (!clean.date_str_en) clean.date_str_en = clean['date_str_en'] || autoDateStrEn || '';
                                    if (!clean.url) clean.url = clean['リンク'] || clean['公式サイト'] || clean['url'] || '';

                                    return clean;
                                }).filter(e => e.title);

                                eventsData = eventsData.filter(e => {
                                    if (!e.end_date) return true; 
                                    const endDate = new Date(e.end_date.replace(/-/g, '/')); 
                                    if (isNaN(endDate.getTime())) return true; 
                                    return endDate >= today; 
                                });
                                
                                eventsData.sort((a, b) => {
                                    const todayTime = today.getTime();
                                    
                                    let startA = a.start_date ? new Date(a.start_date.replace(/-/g, '/')).getTime() : Infinity;
                                    let startB = b.start_date ? new Date(b.start_date.replace(/-/g, '/')).getTime() : Infinity;
                                    if (isNaN(startA)) startA = Infinity;
                                    if (isNaN(startB)) startB = Infinity;

                                    let sortKeyA = startA < todayTime ? todayTime : startA;
                                    let sortKeyB = startB < todayTime ? todayTime : startB;

                                    if (sortKeyA === sortKeyB) {
                                        let endA = a.end_date ? new Date(a.end_date.replace(/-/g, '/')).getTime() : Infinity;
                                        let endB = b.end_date ? new Date(b.end_date.replace(/-/g, '/')).getTime() : Infinity;
                                        if (isNaN(endA)) endA = Infinity;
                                        if (isNaN(endB)) endB = Infinity;
                                        return endA - endB;
                                    }

                                    return sortKeyA - sortKeyB;
                                });

                                renderEvents();
                            } catch (e) { console.warn('Event Data parse warning:', e); }
                        },
                        error: function(err) {
                            eventsData = [];
                            renderEvents(); 
                        }
                    });
                } else {
                    eventsData = [];
                    renderEvents();
                }
            }

            document.querySelectorAll('.tab-item').forEach(tab => {
                tab.addEventListener('click', () => {
                    render(tab.getAttribute('data-area'));
                    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                });
            });
        });
    </script>
</body>
</html>