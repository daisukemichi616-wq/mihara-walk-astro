                if (areaLabels[area]) el.textContent = areaLabels[area][currentLang];
            });
            const langTextEl = document.getElementById('lang-text');
            if (langTextEl) langTextEl.textContent = currentLang === 'jp' ? 'EN' : 'JP';

            if (currentLang === 'en') {
                document.body.classList.add('is-en');
                document.body.classList.remove('is-jp');
            } else {
                document.body.classList.add('is-jp');
                document.body.classList.remove('is-en');
            }

            updateWeatherUI();
            if(spotsData.length > 0) render(currentActiveArea);
            renderLocalInsights(); 
            renderEvents(); 
        }

        window.toggleLanguage = function() {
            currentLang = currentLang === 'jp' ? 'en' : 'jp';
