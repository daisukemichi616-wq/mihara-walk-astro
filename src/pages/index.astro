import Papa from 'papaparse';

// ▼ 1. Astroのビルド時（裏側のサーバー）で三原市のAPIからデータを取得 ▼

// 1-1. 人口データの取得と計算
let popData = { population: 0, households: 0, latestDate: '', isError: false };
let formattedDate = ''; // 表示用の日本語日付

try {
  const popApiUrl = "https://catalog.city.mihara.hiroshima.jp/api/3/action/datastore_search?resource_id=8b68f856-ffe2-48ab-ab71-d011f7982816&limit=3000&sort=" + encodeURIComponent("_id desc");
  const popRes = await fetch(popApiUrl);
  if (!popRes.ok) throw new Error('Network error');
  const popJson = await popRes.json();
  
  if (popJson.success && popJson.result && popJson.result.records) {
    const records = popJson.result.records;
    
    // 過去数カ月分が混ざっているため、一番新しい「基準日」を探し出します
    let latestDate = '';
    records.forEach((row: any) => {
      const d = String(row['基準日'] || '');
      if (d && d > latestDate) latestDate = d;
    });

    let totalPop = 0;
    let totalHouse = 0;
    
    // 抽出した「一番新しい月」のデータだけを足し算します
    records.forEach((row: any) => {
      if (String(row['基準日'] || '') === latestDate) {
        let h = parseInt(row['世帯数'], 10) || 0;
        let m = parseInt(row['男性[人]'], 10) || 0;
        let f = parseInt(row['女性[人]'], 10) || 0;
        totalHouse += h;
        totalPop += (m + f);
      }
    });
    
    if (totalPop > 0) {
      popData.population = totalPop;
      popData.households = totalHouse;
      popData.latestDate = latestDate.split('T')[0].replace(/-/g, '/'); // 例: 2026/02/28
      
      // 日本語の綺麗な日付に変換
      const [y, m, d] = popData.latestDate.split('/');
      formattedDate = `${y}年${parseInt(m)}月${parseInt(d)}日`;
    } else {
      popData.isError = true;
    }
  } else {
    popData.isError = true;
  }
} catch (e) {
  popData.isError = true;
}

// 1-2. 公衆トイレデータの取得
let toiletData = { spots: [] as any[], isError: false };
try {
  const toiletApiUrl = "https://catalog.city.mihara.hiroshima.jp/api/3/action/datastore_search?resource_id=c5f248f0-ab12-4cb6-af0a-fef54523ee00&limit=3000";
  const toiletRes = await fetch(toiletApiUrl);
  if (!toiletRes.ok) throw new Error('Network error');
  const toiletJson = await toiletRes.json();
  if (toiletJson.success && toiletJson.result && toiletJson.result.records) {
    toiletJson.result.records.forEach((row: any) => {
      const name = row['名称'] || row['トイレ名称'] || row['公衆トイレ名'] || '公衆トイレ';
      const lat = parseFloat(row['緯度'] || row['lat']);
      const lng = parseFloat(row['経度'] || row['lng'] || row['lon']);
      if (name && !isNaN(lat) && !isNaN(lng)) {
        toiletData.spots.push({ name, lat, lng });
      }
    });
    if (toiletData.spots.length === 0) {
      toiletData.isError = true;
    }
  } else {
    toiletData.isError = true;
  }
} catch (e) {
  toiletData.isError = true;
}

const safeToiletSpotsJson = JSON.stringify(toiletData.spots).replace(/</g, '\\u003c');


// ▼▼▼ 2. 追加：CSVデータをビルド時に取得し、サーバー側でデータを整形する ▼▼▼

const CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vR0jkQnLXsIL33pmO60BCd0hIr_v5xh34cJ_IWAHkF0pTaj855pzicmNoVx6W8CPK3MEhlp-irodPSE/pub?gid=1232979489&single=true&output=csv";
const LOCAL_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vTia8V00j15toSprtd2bQV4JWrZprRz7m_cf73IZla6KOu62wtunUjCrb9wKkyNthWep8TfDeT8HW2B/pub?gid=1467172273&single=true&output=csv";
const EVENT_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQqAv0S9Shfo2bXUlTuP4jtkZ75D-wt4qCl-P_GOFYMu53peSOEwy7EhbUSUEeBi_T0jehNRIbgp91M/pub?output=csv";

// 汎用CSVフェッチ＆パース関数
async function fetchAndParseCSV(url: string) {
  try {
    const res = await fetch(url);
    if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
    const text = await res.text();
    const result = Papa.parse(text, { header: true, skipEmptyLines: true });
    return result.data;
  } catch (e) {
    console.error(`CSV fetch error for ${url}:`, e);
    return [];
  }
}

// サーバー側で取得
const rawSpots = await fetchAndParseCSV(CSV_URL);
const rawLocal = await fetchAndParseCSV(LOCAL_CSV_URL);
const rawEvents = await fetchAndParseCSV(EVENT_CSV_URL);

// --- 2-1. PHOTO MAP データの整形 ---
const processedSpots = rawSpots.map((row: any) => {
  const clean: any = {};
  Object.keys(row).forEach(k => {
    if (!k) return; 
    let cleanKey = k.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase(); 
    clean[cleanKey] = (typeof row[k] === 'string') ? row[k].trim() : row[k];
  });
  clean.title = clean['スポット名'] || clean['タイトル'] || '';
  clean.desc = clean['紹介文'] || clean['説明'] || '';
  clean.image = clean['写真'] || clean['画像'] || '';
  clean.area = clean['エリア'] || '';
  if (clean.lat_lng_raw) {
    const parts = String(clean.lat_lng_raw).split(',');
    if (parts.length >= 2) {
      clean.lat = parts[0].trim();
      clean.lng = parts[1].trim();
    }
  }
  clean.map_url = clean['googleマップのurl'] || clean['googleマップのurl(共有リンク)'] || clean['地図url'] || '';
  return clean;
}).filter((s: any) => s.title).reverse();

// --- 2-2. みはらさんぽログ データの整形 ---
const processedLocal = rawLocal.map((row: any) => {
  const clean: any = {};
  Object.keys(row).forEach(k => {
    if (!k) return;
    let cleanKey = k.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase(); 
    clean[cleanKey] = (typeof row[k] === 'string') ? row[k].trim() : row[k];
  });
  clean.title = clean['スポット名'] || clean['タイトル'] || '';
  clean.desc = clean['紹介文（パパママ目線）'] || clean['紹介文'] || clean['説明'] || '';
  clean.image = clean['写真'] || clean['画像'] || '';
  clean.area = clean['エリア'] || '';
  clean.tag = clean['タグ'] || '';
  clean.date = clean['タイムスタンプ'] || clean['日付'] || clean['date'] || '';
  if (clean.lat_lng_raw) {
    const parts = String(clean.lat_lng_raw).split(',');
    if (parts.length >= 2) {
      clean.lat = parts[0].trim();
      clean.lng = parts[1].trim();
    }
  }
  return clean;
}).filter((s: any) => s.title).reverse();

// --- 2-3. イベント データの整形 ---
const currentYear = new Date().getFullYear();
const processedEvents = rawEvents.map((row: any) => {
  const clean: any = {};
  Object.keys(row).forEach(k => {
    if (!k) return; 
    let cleanKey = k.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase(); 
    clean[cleanKey] = (typeof row[k] === 'string') ? row[k].trim() : row[k];
  });
  clean.title = clean['イベント名'] || clean['タイトル'] || '';
  clean.desc = clean['説明'] || clean['紹介文'] || '';
  clean.title_en = clean['title_en'] || '';
  clean.desc_en = clean['desc_en'] || '';
  clean.start_date = clean['開始日'] || '';
  clean.end_date = clean['終了日'] || '';

  let autoDateStrJp = '';
  let autoDateStrEn = '';
  
  if (clean.start_date || clean.end_date) {
    const parseD = (str: string) => {
      if(!str) return null;
      const d = new Date(str.replace(/-/g, '/'));
      return isNaN(d.getTime()) ? null : d;
    };
    const sD = parseD(clean.start_date);
    const eD = parseD(clean.end_date);
    
    const fmtFullJp = (d: Date) => `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日(${['日', '月', '火', '水', '木', '金', '土'][d.getDay()]})`;
    const fmtJp = (d: Date) => `${d.getMonth() + 1}月${d.getDate()}日(${['日', '月', '火', '水', '木', '金', '土'][d.getDay()]})`;
    const fmtFullEn = (d: Date) => `${['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'][d.getMonth()]} ${d.getDate()} ${d.getFullYear()} (${['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][d.getDay()]})`;
    const fmtEn = (d: Date) => `${['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'][d.getMonth()]} ${d.getDate()} (${['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][d.getDay()]})`;
    
    if (sD && eD) {
      if (sD.getTime() === eD.getTime()) {
        autoDateStrJp = sD.getFullYear() === currentYear ? fmtJp(sD) : fmtFullJp(sD);
        autoDateStrEn = sD.getFullYear() === currentYear ? fmtEn(sD) : fmtFullEn(sD);
      } else if (sD.getFullYear() === eD.getFullYear()) {
        autoDateStrJp = `${sD.getFullYear() === currentYear ? fmtJp(sD) : fmtFullJp(sD)}〜${fmtJp(eD)}`;
        autoDateStrEn = `${sD.getFullYear() === currentYear ? fmtEn(sD) : fmtFullEn(sD)} - ${fmtEn(eD)}`;
      } else {
        autoDateStrJp = `${fmtFullJp(sD)}〜${fmtFullJp(eD)}`;
        autoDateStrEn = `${fmtFullEn(sD)} - ${fmtFullEn(eD)}`;
      }
    } else if (sD) {
      autoDateStrJp = sD.getFullYear() === currentYear ? fmtJp(sD) : fmtFullJp(sD);
      autoDateStrEn = sD.getFullYear() === currentYear ? fmtEn(sD) : fmtFullEn(sD);
    } else if (eD) {
      autoDateStrJp = `〜${eD.getFullYear() === currentYear ? fmtJp(eD) : fmtFullJp(eD)}`;
      autoDateStrEn = `Until ${eD.getFullYear() === currentYear ? fmtEn(eD) : fmtFullEn(eD)}`;
    }
  }
  clean.date_str = clean['表示用日付'] || clean['日付'] || autoDateStrJp || '';
  clean.date_str_en = clean['date_str_en'] || autoDateStrEn || '';
  clean.url = clean['リンク'] || clean['公式サイト'] || clean['url'] || '';
  return clean;
}).filter((e: any) => e.title);

// JSON文字列化（XSS対策でタグをエスケープ）
const safeSpotsJson = JSON.stringify(processedSpots).replace(/</g, '\\u003c');
const safeLocalJson = JSON.stringify(processedLocal).replace(/</g, '\\u003c');
const safeEventsJson = JSON.stringify(processedEvents).replace(/</g, '\\u003c');
