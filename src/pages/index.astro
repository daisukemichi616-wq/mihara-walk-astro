        let weatherDataCache = null;
        async function fetchWeather() {
            try {
                const lat = 34.3964; const lng = 133.0781;
                const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true&daily=sunrise,sunset,weathercode,temperature_2m_max,temperature_2m_min&timezone=Asia%2FTokyo`;
                const response = await fetch(url);
                if (!response.ok) throw new Error('Weather fetch failed');
                const data = await response.json();
                updateWeatherUI(data);
            } catch (e) {
                console.error('Weather API Error:', e);
                const tempEl = document.getElementById('weather-temp-text');
                if (tempEl) tempEl.textContent = '--°C';
            }
        }

        function updateWeatherUI(data) {
            if (data) weatherDataCache = data;
            else data = weatherDataCache;
            if (!data) return;

            try {
                const current = data.current_weather;
                const daily = data.daily;
                const currentInfo = getWeatherInfo(current.weathercode, currentLang);

                const mainIcon = document.getElementById('weather-main-icon');
                if(mainIcon) mainIcon.className = `fa-solid ${currentInfo.iconClass} text-lg`;
                
                const tempText = document.getElementById('weather-temp-text');
                if(tempText) tempText.textContent = `${current.temperature}°C`;

                const formatTime = (date) => `${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}`;
                const sunsetStr = formatTime(new Date(daily.sunset[0]));

                let magicHourPreText = currentLang === 'en' ? 'Sunset: ' : '夕焼け: ';
                
                const magicText = document.getElementById('magic-hour-text');
                if(magicText) magicText.textContent = magicHourPreText + sunsetStr;

                const weeklyList = document.getElementById('weekly-forecast-list');
                if(weeklyList) {
                    weeklyList.innerHTML = '';
                    for(let i = 0; i < 7; i++) {
                        const dObj = new Date(daily.time[i]);
                        const dayJp = ['日', '月', '火', '水', '木', '金', '土'][dObj.getDay()];
                        const dayEn = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][dObj.getDay()];
                        const dayLabel = currentLang === 'en' ? dayEn : dayJp;
                        const maxT = Math.round(daily.temperature_2m_max[i]);
                        const minT = Math.round(daily.temperature_2m_min[i]);
                        const wInfo = getWeatherInfo(daily.weathercode[i], currentLang);
                        
                        const dayEl = document.createElement('div');
                        dayEl.className = "flex flex-col items-center flex-1 min-w-[42px]";
                        dayEl.innerHTML = `
                            <span class="text-[10px] text-gray-400 font-bold mb-1.5 weekly-day-label">${i === 0 ? (currentLang === 'en' ? 'Today' : '今日') : dayLabel}</span>
                            <i class="fa-solid ${wInfo.iconClass} text-[15px] mb-1.5"></i>
                            <div class="text-[9px] font-bold flex gap-1.5 mt-auto">
                                <span class="text-red-400">${maxT}°</span><span class="text-blue-500">${minT}°</span>
                            </div>
                        `;
                        weeklyList.appendChild(dayEl);
                    }
                }
            } catch(e) {
                console.warn('Weather UI Error:', e);
            }
        }

        function getWeatherInfo(code, lang) {
            let iconClass = 'fa-cloud text-gray-400';
            if (code === 0) { iconClass = 'fa-sun text-orange-500'; }
            else if (code === 1 || code === 2) { iconClass = 'fa-cloud-sun text-orange-400'; }
            else if (code === 3) { iconClass = 'fa-cloud text-gray-400'; }
            else if (code === 45 || code === 48) { iconClass = 'fa-smog text-gray-400'; }
            else if (code >= 51 && code <= 67) { iconClass = 'fa-umbrella text-blue-500'; }
            else if (code >= 71 && code <= 77) { iconClass = 'fa-snowflake text-blue-300'; }
            else if (code >= 80 && code <= 82) { iconClass = 'fa-cloud-showers-heavy text-blue-600'; }
            else if (code >= 95) { iconClass = 'fa-bolt text-yellow-500'; }
            return { iconClass };
        }

