                        trigger: '.hero-view',
                        start: "top top",
                        end: "bottom top",
                        scrub: true
                    }
                });
            }

            // ▼ 人口カウントアップのアニメーション ▼
            let isCounted = false;
            ScrollTrigger.create({
                trigger: '#about',
                start: 'top 80%', 
                onEnter: () => {
                    if(isCounted) return;
                    isCounted = true;
                    document.querySelectorAll('.count-up').forEach(el => {
                        const endVal = parseInt(el.getAttribute('data-val'), 10) || 0;
                        if (endVal === 0) return; 
                        const obj = { val: 0 };
                        
                        gsap.to(obj, {
                            val: endVal,
                            duration: 3,
