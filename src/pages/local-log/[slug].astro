---
// 1. Astroのビルド時に実行される処理（サーバーサイド）
export async function getStaticPaths() {
  // スプレッドシート（CSV形式で公開したもの）のURL
  const LOCAL_CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vTia8V00j15toSprtd2bQV4JWrZprRz7m_cf73IZla6KOu62wtunUjCrb9wKkyNthWep8TfDeT8HW2B/pub?gid=1467172273&single=true&output=csv";
  
  const response = await fetch(LOCAL_CSV_URL);
  const csvText = await response.text();

  // CSVをパース（解析）する関数
  function parseCSV(text) {
    const result = [];
    let row = [];
    let current = '';
    let inQuotes = false;
    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      if (char === '"') {
        if (inQuotes && text[i + 1] === '"') { current += '"'; i++; }
        else { inQuotes = !inQuotes; }
      } else if (char === ',' && !inQuotes) {
        row.push(current); current = '';
      } else if ((char === '\n' || char === '\r') && !inQuotes) {
        if (char === '\r' && text[i + 1] === '\n') { i++; }
        row.push(current); result.push(row); row = []; current = '';
      } else { current += char; }
    }
    if (current !== '' || row.length > 0) { row.push(current); result.push(row); }
    return result;
  }

  const rows = parseCSV(csvText);
  if (rows.length < 2) return [];

  // ヘッダー行を整形（空白削除・小文字化）
  const header = rows[0].map(h => h.replace(/^[\s\u3000]+|[\s\u3000]+$/g, '').toLowerCase());
  
  const spots = [];
  for(let i=1; i<rows.length; i++) {
    const values = rows[i];
    if(!values || values.length <= 1) continue;
    
    // 一旦生のデータを取得
    const rawSpot = {};
    header.forEach((h, index) => {
      rawSpot[h] = values[index] ? values[index].trim() : '';
    });

    // 💡【重要修正】日本語の列名を、プログラムが読める英語名に正確に翻訳（ひも付け）する
    const spot = {};
    spot.title = rawSpot['スポット名'] || rawSpot['タイトル'] || rawSpot['title'] || '';
    spot.desc = rawSpot['紹介文（パパママ目線）'] || rawSpot['紹介文'] || rawSpot['説明'] || rawSpot['desc'] || '';
    spot.image = rawSpot['写真'] || rawSpot['画像'] || rawSpot['image'] || '';
    spot.area = rawSpot['エリア'] || rawSpot['area'] || '';
    spot.tag = rawSpot['タグ'] || rawSpot['tag'] || '';
    spot.lat_lng_raw = rawSpot['lat_lng_raw'] || rawSpot['緯度経度'] || '';
    spot.map_url = rawSpot['googleマップのurl'] || rawSpot['googleマップのurl(共有リンク)'] || rawSpot['地図url'] || rawSpot['map_url'] || '';
    spot.author = rawSpot['ニックネーム'] || rawSpot['撮影者'] || rawSpot['author'] || rawSpot['nickname'] || '';
    spot.sns = rawSpot['sns'] || rawSpot['snsurl'] || rawSpot['url'] || rawSpot['link'] || '';

    if(spot.title) {
      spots.push(spot);
    }
  }

  // 記事の数だけページ（URL）を生成
  return spots.map(spot => {
    // タイトルをURLのスラッグとして使用（記号はハイフンに置換）
    let slug = spot.title.replace(/[\/\\]/g, '-');
    
    return {
      params: { slug: slug },
      props: { spot }, // 各コンポーネントにデータを渡す
    };
  });
}

// 2. 各ページに渡されたデータを受け取る
const { spot } = Astro.props;

// 💡 画像URLの整形（複数画像への対応と、安定した高画質URLへの変換）
let rawImage = spot.image || '';
// カンマ区切りで複数の写真が入っている場合は、最初の1枚目だけを取り出す
let firstImage = rawImage.includes(',') ? rawImage.split(',')[0].trim() : rawImage.trim();

let imageUrl = "https://placehold.co/600x800/e2e8f0/94a3b8?text=No+Image";
let driveId = "";

if (firstImage) {
  const idMatch = firstImage.match(/[-\w]{25,}/);
  if (idMatch) {
    driveId = idMatch[0];
    // 最も安定して表示されるGoogleの画像サーバーURLを使用
    imageUrl = `https://lh3.googleusercontent.com/d/${driveId}=w1200`;
  } else if (firstImage.startsWith('http')) {
    imageUrl = firstImage;
  }
}

// Googleマップ用URLの準備
let mapUrl = spot.map_url || '';
if(!mapUrl && spot.lat_lng_raw) {
   // 緯度経度がある場合のフォールバック
   mapUrl = `https://www.google.com/maps/search/?api=1&query=${spot.lat_lng_raw}`;
}
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  
  <title>{spot.title} | みはら親子さんぽログ</title>
  <meta name="description" content={spot.desc}>
  
  <meta property="og:type" content="article">
  <meta property="og:title" content={`${spot.title} | みはら親子さんぽログ`}>
  <meta property="og:description" content={spot.desc}>
  <meta property="og:image" content={imageUrl}>
  <meta name="twitter:card" content="summary_large_image">

  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Noto+Serif+JP:wght@700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <style>
    body { 
      font-family: 'Zen Maru Gothic', sans-serif; 
      color: #1a1a1a; 
      background-color: #f1f5f9; 
      word-break: break-all;
    }
    .serif-custom { font-family: 'Noto Serif JP', serif; }
  </style>

  <!-- 💡 画像がブロックされた時用の最強の予備プログラム（トップページと同じもの） -->
  <script is:inline>
    function handleFallbackErr(img, driveId) {
      if (!img || !driveId) return;
      const step = parseInt(img.dataset.fStep || '0');
      if (step === 0) {
        img.dataset.fStep = '1';
        img.src = 'https://drive.google.com/uc?export=view&id=' + driveId;
      } else if (step === 1) {
        img.dataset.fStep = '2';
        img.src = 'https://drive.google.com/thumbnail?id=' + driveId + '&sz=w1000';
      } else if (step === 2) {
        img.dataset.fStep = '3';
        img.src = 'https://wsrv.nl/?url=https://drive.google.com/uc?export=view%26id=' + driveId;
      } else {
        img.onerror = null;
        img.src = 'https://placehold.co/600x800/e2e8f0/94a3b8?text=Image+Blocked';
      }
    }
  </script>
</head>
<body>
  
  <nav class="bg-white/90 backdrop-blur-md border-b border-gray-200 px-4 py-3 sticky top-0 z-50 flex items-center justify-between shadow-sm">
      <!-- 💡 戻るボタンのリンク先を /#local-insights に変更し、テキストを修正 -->
      <a href="/#local-insights" class="text-[#004098] font-bold text-xs sm:text-sm flex items-center gap-2 hover:opacity-70 transition">
        <i class="fa-solid fa-arrow-left"></i> さんぽログへ戻る
      </a>
      <div class="text-[10px] sm:text-xs font-bold text-gray-400 tracking-widest uppercase">Mihara Rediscover</div>
  </nav>

  <main class="max-w-3xl mx-auto bg-white min-h-screen shadow-md pb-24">
    
    <!-- 💡 画像の枠の縦幅を長くし(h-[60vh])、画像が切れない設定(object-contain)に変更 -->
    <div class="w-full h-[60vh] sm:h-[80vh] bg-[#f8f9fa] flex items-center justify-center relative">
        <img 
            src={imageUrl} 
            alt={spot.title} 
            class="w-full h-full object-contain" 
            data-f-step="0" 
            onerror={`handleFallbackErr(this, '${driveId}')`} 
        />
        <div class="absolute top-4 left-4 bg-[#004098]/90 text-white text-[10px] font-bold px-3 py-1.5 rounded flex items-center gap-1.5 shadow-lg z-10">
            <i class="fa-solid fa-location-dot"></i> {spot.area || '三原市'}
        </div>
    </div>
    
    <div class="px-6 sm:px-10 py-8 sm:py-12">
        
       <div class="flex items-center gap-2 mb-4">
         <span class="text-[#004098] bg-blue-50 border border-blue-100 text-[10px] font-bold px-2 py-1 rounded">🎒 親子でお散歩</span>
       </div>
       
       <h1 class="text-2xl sm:text-3xl font-bold text-[#004098] serif-custom mb-8 leading-relaxed border-b-2 border-blue-50 pb-6">
           {spot.title}
       </h1>
       
       <!-- 💡 紹介文のURLを自動でリンクにするスクリプト -->
       <div id="desc-container" class="text-gray-700 leading-loose text-sm sm:text-base whitespace-pre-line mb-12">
         {spot.desc}
       </div>
       <script is:inline>
         const descEl = document.getElementById('desc-container');
         if (descEl) {
           const urlRegex = /(https?:\/\/[^\s<]+)/g;
           descEl.innerHTML = descEl.innerHTML.replace(urlRegex, function(url) {
             return `<a href="${url}" target="_blank" rel="noopener noreferrer" style="color: #004098; text-decoration: underline;">${url}</a>`;
           });
         }
       </script>

       {mapUrl && (
         <a href={mapUrl} target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-blue-50 text-[#004098] border border-[#004098] font-bold py-4 rounded-lg hover:bg-[#004098] hover:text-white transition-all shadow-sm">
           <i class="fa-solid fa-map-location-dot mr-2"></i> この場所をGoogleマップで見る
         </a>
       )}

       {spot.sns && (
         <a href={spot.sns} target="_blank" rel="noopener noreferrer" class="block w-full mt-4 text-center text-white font-bold py-4 rounded-lg shadow-md transition-transform hover:-translate-y-1" style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
           <i class="fa-brands fa-instagram text-xl mr-2 align-middle"></i> Instagramでこの投稿を見る
         </a>
       )}
       
       <div class="mt-16 pt-8 border-t border-dashed border-gray-200 flex justify-between items-center text-[10px] sm:text-xs font-bold text-gray-400 tracking-widest uppercase">
         <span>Photo by {spot.author || 'みはらさんぽ'}</span>
         <span>Share the Charm</span>
       </div>
       
    </div>
  </main>

</body>
</html>